MANPAGES_CCMD_MENU_MOUSE_NAME         = "menu_mouse";
MANPAGES_CCMD_MENU_MOUSE_DESC         = "Activates the {{mouse configuration}} menu.";
MANPAGES_CCMD_MENU_MOUSE_EXMP         = "";
MANPAGES_CCMD_MENU_OPTIONS_NAME       = "menu_options";
MANPAGES_CCMD_MENU_OPTIONS_DESC       = "Activates the {{options menu}}.";
MANPAGES_CCMD_MENU_OPTIONS_EXMP       = "";
MANPAGES_CCMD_MENU_PLAYER_NAME        = "menu_player";
MANPAGES_CCMD_MENU_PLAYER_DESC        = "Activates the {{player setup}} menu.";
MANPAGES_CCMD_MENU_PLAYER_EXMP        = "";
MANPAGES_CCMD_MENU_QUIT_NAME          = "menu_quit";
MANPAGES_CCMD_MENU_QUIT_DESC          = "Activates the {{quit menu}} which asks the user if they want to quit, and quits if they do.";
MANPAGES_CCMD_MENU_QUIT_EXMP          = "";
MANPAGES_CCMD_MENU_SAVE_NAME          = "menu_save";
MANPAGES_CCMD_MENU_SAVE_DESC          = "Activates the {{save game menu}}.";
MANPAGES_CCMD_MENU_SAVE_EXMP          = "";
MANPAGES_CCMD_MENU_SCOREBOARD_NAME    = "menu_scoreboard";
MANPAGES_CCMD_MENU_SCOREBOARD_DESC    = "Activates the {{scoreboard options}} menu.";
MANPAGES_CCMD_MENU_SCOREBOARD_EXMP    = "";
MANPAGES_CCMD_MENU_SOUND_NAME         = "menu_sound";
MANPAGES_CCMD_MENU_SOUND_DESC         = "Activates the {{sound options}} menu.";
MANPAGES_CCMD_MENU_SOUND_EXMP         = "";
MANPAGES_CCMD_MENU_VIDEO_NAME         = "menu_video";
MANPAGES_CCMD_MENU_VIDEO_DESC         = "Activates the {{video mode}} menu.";
MANPAGES_CCMD_MENU_VIDEO_EXMP         = "";
MANPAGES_CCMD_MESSAGEMODE_NAME        = "messagemode";
MANPAGES_CCMD_MESSAGEMODE_DESC        = "Enters message entry mode. Anything typed while in this mode will be sent to everyone else as if you had used the say command once you press enter.";
MANPAGES_CCMD_MESSAGEMODE_EXMP        = "";
MANPAGES_CCMD_MONSTER_NAME            = "monster [class or TID]";
MANPAGES_CCMD_MONSTER_DESC            = "Prints a list of all living, unfriendly {{monsters}} present in the map, each on a line of the form ClassName at (X, Y, Z).\n\nPassing a monster's class name to the command, filters the list, listing only those with the matching class name. At the end of the list, the total count of found monsters is printed. Passing a TID instead of a class name, filters the list by TID.";
MANPAGES_CCMD_MONSTER_EXMP            = "";
MANPAGES_CCMD_MONSTERNUM_NAME         = "monsternum [class or TID]";
MANPAGES_CCMD_MONSTERNUM_DESC         = "Prints the total count of all living, unfriendly monsters present in the map. Passing a monster's class name to the command, prints the total count of that class only. Passing a TID instead of a class name, prints the total count of monsters with the matching TID.";
MANPAGES_CCMD_MONSTERNUM_EXMP         = "";
MANPAGES_CCMD_MORPHME_NAME            = "morphme [class]";
MANPAGES_CCMD_MORPHME_DESC            = "Transforms you into a chicken in Heretic and a pig in Hexen and Doom (The latter only happens if you have the relevant graphics present). Additionally, if \"class\" is specified, it will attempt to morph you into the supplied class. This will only work if the target class is inherited from PlayerPawn, and you are not in a state that cannot otherwise morph (i.e. death).";
MANPAGES_CCMD_MORPHME_EXMP            = "";
MANPAGES_CCMD_MYINFO_NAME             = "myinfo";
MANPAGES_CCMD_MYINFO_DESC             = "Prints a lot of information about the playerpawn you are controlling in a similar manner to \"info\".";
MANPAGES_CCMD_MYINFO_EXMP             = "";
MANPAGES_CCMD_NET_ADDCONTROLLER_NAME  = "net_addcontroller <player>";
MANPAGES_CCMD_NET_ADDCONTROLLER_DESC  = "Adds a player to the list of controllers who are able to change game settings.";
MANPAGES_CCMD_NET_ADDCONTROLLER_EXMP  = "";
MANPAGES_CCMD_NET_LISTCONTROLLERS_NAME = "net_listcontrollers";
MANPAGES_CCMD_NET_LISTCONTROLLERS_DESC = "Lists the current controllers.";
MANPAGES_CCMD_NET_LISTCONTROLLERS_EXMP = "";
MANPAGES_CCMD_NET_REMOVECONTROLLER_NAME = "net_removecontroller <player>";
MANPAGES_CCMD_NET_REMOVECONTROLLER_DESC = "Removes a player from the list of controllers.";
MANPAGES_CCMD_NET_REMOVECONTROLLER_EXMP = "";
MANPAGES_CCMD_NEXTMAP_NAME            = "nextmap";
MANPAGES_CCMD_NEXTMAP_DESC            = "Warps the player to the next map as specified by {{MAPINFO}}.  Also resets the player's inventory and health as if a new game had been started.";
MANPAGES_CCMD_NEXTMAP_EXMP            = "";
MANPAGES_CCMD_NEXTSECRET_NAME         = "nextsecret";
MANPAGES_CCMD_NEXTSECRET_DESC         = "Warps the player to the current secret map as specified by {{MAPINFO}}, just as if he had found the secret exit in this map.  Also resets the player's inventory and health as if a new game had been started.";
MANPAGES_CCMD_NEXTSECRET_EXMP         = "";
MANPAGES_CCMD_NOCLIP_NAME             = "noclip";
MANPAGES_CCMD_NOCLIP_DESC             = "Toggles noclipping mode on/off. With this mode, you can walk through walls and solid actors, and are able to step up by an infinite amount.  Basically your horizontal movement will never be restricted.  This can be useful for passing through locked doors or quickly accessing later parts of a map.";
MANPAGES_CCMD_NOCLIP_EXMP             = "";
MANPAGES_CCMD_NOCLIP2_NAME            = "noclip2";
MANPAGES_CCMD_NOCLIP2_DESC            = "Toggles noclipping mode 2 on/off. This is similar to the {{noclip}} command, except it also toggles the {{NOGRAVITY}} flag on and gives the ability to fly through {{3D floors}}.";
MANPAGES_CCMD_NOCLIP2_EXMP            = "";
MANPAGES_CCMD_NOTARGET_NAME           = "notarget";
MANPAGES_CCMD_NOTARGET_DESC           = "Toggles notarget mode on/off. While active, monsters will not target you unless you hurt them first. In \"modern FPS\", monsters \"can't find you\" when in notarget mode. This is not the case with ZDoom.";
MANPAGES_CCMD_NOTARGET_EXMP           = "";
MANPAGES_CCMD_OPEN_NAME               = "open <path & filename> [dm|coop]";
MANPAGES_CCMD_OPEN_DESC               = "Opens the given file and loads the first map found in it. The rest of the loaded file is ignored - custom graphics and sounds, {{MAPINFO}} and actor definitions, maps beyond the first, etc., all that are ignored. The map name and slot will be the provided file name, rather than the map's actual slot within the file. Inventory and health are reset as if starting a new game. This command cannot be used in {{multiplayer}} mode. Like with map, the dm or coop keyword can be added to set the game mode to emulated {{multiplayer}}. Without this keyword the game mode defaults to single-player.";
MANPAGES_CCMD_OPEN_EXMP               = "";
MANPAGES_CCMD_OPENMENU_NAME           = "openmenu <menu_name>";
MANPAGES_CCMD_OPENMENU_DESC           = "Opens the given {{menu}}, using its {{MENUDEF}} name.";
MANPAGES_CCMD_OPENMENU_EXMP           = "";
MANPAGES_CCMD_PAUSE_NAME              = "pause";
MANPAGES_CCMD_PAUSE_DESC              = "Pauses and unpauses the game.";
MANPAGES_CCMD_PAUSE_EXMP              = "";
MANPAGES_CCMD_PINGS_NAME              = "pings";
MANPAGES_CCMD_PINGS_DESC              = "This lists a very rough estimate of the speed of the connection between your machine and any others in the game. In reality, the values printed by this command aren't even pings; they're just the number of milliseconds that have passed since the last time you received a network packet from the other machines.";
MANPAGES_CCMD_PINGS_EXMP              = "";
MANPAGES_CCMD_PLAYDEMO_NAME           = "playdemo <demo>";
MANPAGES_CCMD_PLAYDEMO_DESC           = "Plays a demo. The demo can be a file on disk or a lump in a wad.";
MANPAGES_CCMD_PLAYDEMO_EXMP           = "";
MANPAGES_CCMD_PLAYERCLASSES_NAME      = "playerclasses";
MANPAGES_CCMD_PLAYERCLASSES_DESC      = "Lists all available {{player classes}}, giving for each a number (starting at zero), the class' actor name, and the class' display name.";
MANPAGES_CCMD_PLAYERCLASSES_EXMP      = "";
MANPAGES_CCMD_PLAYERINFO_NAME         = "playerinfo [player]";
MANPAGES_CCMD_PLAYERINFO_DESC         = "Without parameters, lists the numbers for each player in the game. If you specify a {{player}}, then details about that player's user info will be listed.";
MANPAGES_CCMD_PLAYERINFO_EXMP         = "";
MANPAGES_CCMD_PLAYERSOUNDS_NAME       = "playersounds";
MANPAGES_CCMD_PLAYERSOUNDS_DESC       = "Lists the player sounds defined by each player class and skin.";
MANPAGES_CCMD_PLAYERSOUNDS_EXMP       = "";
MANPAGES_CCMD_PLAYLIST_NAME           = "playlist <playlist.m3u> [shuffle|position]";
MANPAGES_CCMD_PLAYLIST_DESC           = "Loads a WinAmp .m3u playlist. Any music that would normally be played will be ignored, and the songs in the playlist will be played instead. If you add the word shuffle after the name of the .m3u file, the playlist will be replayed in a random order. In place of shuffle, you can also specify {{position}}, a number corresponding to the song number in the playlist you want to play first.";
MANPAGES_CCMD_PLAYLIST_EXMP           = "";
MANPAGES_CCMD_PLAYLISTNEXT_NAME       = "playlistnext";
MANPAGES_CCMD_PLAYLISTNEXT_DESC       = "Plays the next song in the playlist.";
MANPAGES_CCMD_PLAYLISTNEXT_EXMP       = "";
MANPAGES_CCMD_PLAYLISTPOS_NAME        = "playlistpos <position>";
MANPAGES_CCMD_PLAYLISTPOS_DESC        = "Starts playing the song at the specified {{position}} in the playlist.";
MANPAGES_CCMD_PLAYLISTPOS_EXMP        = "";
MANPAGES_CCMD_PLAYLISTPREV_NAME       = "playlistprev";
MANPAGES_CCMD_PLAYLISTPREV_DESC       = "Plays the previous song in the playlist.";
MANPAGES_CCMD_PLAYLISTPREV_EXMP       = "";
MANPAGES_CCMD_PLAYLISTSTATUS_NAME     = "playliststatus";
MANPAGES_CCMD_PLAYLISTSTATUS_DESC     = "Displays the number of songs in the playlist and the currently playing song.";
MANPAGES_CCMD_PLAYLISTSTATUS_EXMP     = "";
MANPAGES_CCMD_PLAYSEQUENCE_NAME       = "playsequence <sequence> [<number>]";
MANPAGES_CCMD_PLAYSEQUENCE_DESC       = "Plays a {{sound sequence}} on the local machine. If a number is not given, 0 is used. The {{sequence}} must be defined in {{SNDSEQ}}.";
MANPAGES_CCMD_PLAYSEQUENCE_EXMP       = "";
MANPAGES_CCMD_PLAYSOUND_NAME          = "playsound <sound>";
MANPAGES_CCMD_PLAYSOUND_DESC          = "Plays a sound on the local machine. Like all other sounds in the game, {{sound}} must be properly defined in a {{SNDINFO}} lump before you can use it.";
MANPAGES_CCMD_PLAYSOUND_EXMP          = "";
MANPAGES_CCMD_POWERUP_NAME            = "powerup";
MANPAGES_CCMD_POWERUP_DESC            = "Powers you up in Heretic as if you had used a Tome of Power.";
MANPAGES_CCMD_POWERUP_EXMP            = "";
MANPAGES_CCMD_PRINT_NAME              = "print <string>";
MANPAGES_CCMD_PRINT_DESC              = "Prints a named string to the console. These are the strings you can edit with a bex patch.";
MANPAGES_CCMD_PRINT_EXMP              = "";
MANPAGES_CCMD_PRINTINV_NAME           = "printinv";
MANPAGES_CCMD_PRINTINV_DESC           = "Prints your current inventory to the console.";
MANPAGES_CCMD_PRINTINV_EXMP           = "";
MANPAGES_CCMD_PRINTSTATS_NAME         = "printstats";
MANPAGES_CCMD_PRINTSTATS_DESC         = "Prints your statistics (kills, secrets, items, and time) for each level in the current game.";
MANPAGES_CCMD_PRINTSTATS_EXMP         = "";
MANPAGES_CCMD_PUKE_NAME               = "puke <script> [arg1 [arg2 [arg3]]]";
MANPAGES_CCMD_PUKE_DESC               = "Executes an {{ACS}} script on the current map, optionally passing it up to three numerical arguments. If you try this on {{multiplayer}}, {{sv_cheats}} must normally be enabled. However, if the script has the \"net\" keyword, it can be activated by anyone in a multiplayer game.\n\nIf the \"script\" argument is a negative value, the script will be executed as if it had been called by {{ACS_ExecuteAlways}}; otherwise it will be executed as if called by {{ACS_Execute}}. Script 0 is reserved for {{Strife}} support and cannot be puked.";
MANPAGES_CCMD_PUKE_EXMP               = "";
MANPAGES_CCMD_PUKENAME_NAME           = "pukename <script> [always] [arg1 [arg2 [arg3]]]";
MANPAGES_CCMD_PUKENAME_DESC           = "Executes a {{named script}} on the current map, optionally passing it up to three numerical arguments. If you try this on {{multiplayer}}, {{sv_cheats}} must normally be enabled. However, if the script has the \"net\" keyword, it can be activated by anyone in a multiplayer game.\n\nIf the always keyword is placed after the script name (and before any optional argument), the script will be executed as if it had been called by {{ACS_NamedExecuteAlways}}; otherwise it will be executed as if called by {{ACS_NamedExecute}}.";
MANPAGES_CCMD_PUKENAME_EXMP           = "";
MANPAGES_CCMD_PULLIN_NAME             = "pullin <wadfile>";
MANPAGES_CCMD_PULLIN_DESC             = "Loads a wadfile at startup. This command is only valid inside .cfg files that have been executed at startup.";
MANPAGES_CCMD_PULLIN_EXMP             = "";
MANPAGES_CCMD_REBIND_NAME             = "rebind <command>";
MANPAGES_CCMD_REBIND_DESC             = "Changes the binding for the key that caused the rebind command to execute. For obvious reasons, this command cannot be used directly from the console.\n\nFor example, this command will cause the first press of b to echo \"setting 1\" to the console. All future presses of b will echo \"setting 2\" instead.:\nbind b \"echo setting 1; rebind \\"echo setting 2\\"\"";
MANPAGES_CCMD_REBIND_EXMP             = "";
MANPAGES_CCMD_RECORDMAP_NAME          = "recordmap <filename> <map name> [dm|coop]";
MANPAGES_CCMD_RECORDMAP_DESC          = "Starts a new game on the specified map, recording a demo to the specified filename. Passing * instead of a map name records a demo of the current map. Optionally the dm or coop keyword can be added to set the game mode to emulated {{multiplayer}}. Without this keyword the game mode defaults to single-player.";
MANPAGES_CCMD_RECORDMAP_EXMP          = "";
MANPAGES_CCMD_REMOVE_NAME             = "remove <class>";
MANPAGES_CCMD_REMOVE_DESC             = "Removes all entities of the type specified from the current map, except for live players.\n\n{{WARNING:}} Removing voodoo dolls may break maps which rely upon triggering line specials, and should be avoided.\n\n{{NOTE:}} This command does not have any categories, and only corresponds with actor names. I.e. 'remove monsters' will not remove all monsters, though expansion of this command is planned to include some categories.";
MANPAGES_CCMD_REMOVE_EXMP             = "";
MANPAGES_CCMD_REMOVEBOTS_NAME         = "removebots";
MANPAGES_CCMD_REMOVEBOTS_DESC         = "Removes any bots from the game. Bots will also be automatically removed from network games when the arbitrator quits.";
MANPAGES_CCMD_REMOVEBOTS_EXMP         = "";
MANPAGES_CCMD_RESET2DEFAULTS_NAME     = "reset2defaults";
MANPAGES_CCMD_RESET2DEFAULTS_DESC     = "Resets all {{console variables}} and key bindings to their default values.";
MANPAGES_CCMD_RESET2DEFAULTS_EXMP     = "";
MANPAGES_CCMD_RESET2SAVED_NAME        = "reset2saved";
MANPAGES_CCMD_RESET2SAVED_DESC        = "Resets all {{console variables}} and key bindings to the values they currently have in {{the ini}}.";
MANPAGES_CCMD_RESET2SAVED_EXMP        = "";
MANPAGES_CCMD_RESETCVAR_NAME          = "resetcvar <cvar>";
MANPAGES_CCMD_RESETCVAR_DESC          = "Resets {{cvar}} to the default value.";
MANPAGES_CCMD_RESETCVAR_EXMP          = "";
MANPAGES_CCMD_RESURRECT_NAME          = "resurrect";
MANPAGES_CCMD_RESURRECT_DESC          = "When dead, resurrects the player (brings him back alive and to 100% health). Note - cannot be used when the player is \"broken apart\" e.g. shattered to pieces after being frozen.";
MANPAGES_CCMD_RESURRECT_EXMP          = "";
MANPAGES_CCMD_SAY_NAME                = "say <message>";
MANPAGES_CCMD_SAY_DESC                = "Sends a message to everyone playing. If your message begins with \"/me\" then \"/me\" will be replaced by your name ala IRC.";
MANPAGES_CCMD_SAY_EXMP                = "";
MANPAGES_CCMD_SAY_TEAM_NAME           = "say_team <message>";
MANPAGES_CCMD_SAY_TEAM_DESC           = "This is just like say except it only sends a message to your teammates. If teamplay is inactive, then this command will act exactly like say and send the message to everyone.";
MANPAGES_CCMD_SAY_TEAM_EXMP           = "";
MANPAGES_CCMD_SCREENSHOT_NAME         = "screenshot [file]";
MANPAGES_CCMD_SCREENSHOT_DESC         = "Dumps {{a copy of the screen}} to disk as a PNG or PCX file. If file is not specified, the screenshot filename will be in a set format which include the name of the IWAD being used and the time the shot was taken.";
MANPAGES_CCMD_SCREENSHOT_EXMP         = "";
MANPAGES_CCMD_SCRIPTSTAT_NAME         = "scriptstat";
MANPAGES_CCMD_SCRIPTSTAT_DESC         = "Lists the scripts running on the current level.";
MANPAGES_CCMD_SCRIPTSTAT_EXMP         = "";
MANPAGES_CCMD_SECRET_NAME             = "secret";
MANPAGES_CCMD_SECRET_DESC             = "If a {{SECRETS}} lump is provided and covers the current map, prints a list of hints meant to help the player find the secrets.";
MANPAGES_CCMD_SECRET_EXMP             = "";
MANPAGES_CCMD_SELECT_NAME             = "select <item>";
MANPAGES_CCMD_SELECT_DESC             = "Selects the given {{artifact}}, provided there is one in inventory.";
MANPAGES_CCMD_SELECT_EXMP             = "";
MANPAGES_CCMD_SET_NAME                = "set <CVAR> <value>";
MANPAGES_CCMD_SET_DESC                = "Sets {{CVAR}} to {{value}}. If {{CVAR}} does not exist, it will be created.";
MANPAGES_CCMD_SET_EXMP                = "";
MANPAGES_CCMD_SETSLOT_NAME            = "setslot <slot> [<weapon1> [<weapon2> [...]]] (deprecated)";
MANPAGES_CCMD_SETSLOT_DESC            = "Clears the given weapon slot entirely, then fill it with the given weapons. If no slot is specified and no slots are given, the command prints to the console how the slots are currently filled. As of ZDoom 2.3.0, this has been deprecated and new ways of adding weapon slots are available, such as the {{Player.WeaponSlot}} or {{Weapon.SlotNumber}} property.";
MANPAGES_CCMD_SETSLOT_EXMP            = "";
MANPAGES_CCMD_SHOWPOP_NAME            = "showpop <number>";
MANPAGES_CCMD_SHOWPOP_DESC            = "Display a {{Strife}}-style pop-up. The {{number}} can be:\n- Log / mission objectives\n- Key list\n- Status / weapons, ammo, and statistics";
MANPAGES_CCMD_SHOWPOP_EXMP            = "";
MANPAGES_CCMD_SIZEDOWN_NAME           = "sizedown";
MANPAGES_CCMD_SIZEDOWN_DESC           = "Decrements {{screenblocks}} by 1, shrinking the view window.";
MANPAGES_CCMD_SIZEDOWN_EXMP           = "";
MANPAGES_CCMD_SIZEUP_NAME             = "sizeup";
MANPAGES_CCMD_SIZEUP_DESC             = "Increments {{screenblocks}} by 1, enlarging the view window.";
MANPAGES_CCMD_SIZEUP_EXMP             = "";
MANPAGES_CCMD_SKINS_NAME              = "skins";
MANPAGES_CCMD_SKINS_DESC              = "Lists the names of the skins that were loaded when the game was started.";
MANPAGES_CCMD_SKINS_EXMP              = "";
MANPAGES_CCMD_SKYFOG_NAME             = "skyfog <value>";
MANPAGES_CCMD_SKYFOG_DESC             = "Changes the density of the fog that affects the {{sky}} plane. This allows to test sky fog sheets.";
MANPAGES_CCMD_SKYFOG_EXMP             = "";
MANPAGES_CCMD_SLOT_NAME               = "slot <slotnumber>";
MANPAGES_CCMD_SLOT_DESC               = "Selects the next {{weapon}} from the specified {{weapon slot}}.";
MANPAGES_CCMD_SLOT_EXMP               = "";
MANPAGES_CCMD_SND_LISTDRIVERS_NAME    = "snd_listdrivers";
MANPAGES_CCMD_SND_LISTDRIVERS_DESC    = "Lists the drivers supported by the current {{snd_output}} setting.";
MANPAGES_CCMD_SND_LISTDRIVERS_EXMP    = "";
MANPAGES_CCMD_SND_LISTMIDIDEVICES_NAME = "snd_listmididevices";
MANPAGES_CCMD_SND_LISTMIDIDEVICES_DESC = "This command lists the {{MIDI devices}} available in the system. Devices in this list can be used in the {{snd_mididevice}} cvar to select which device plays music. Devices with negative numbers are provided by {{ZDoom}} itself.";
MANPAGES_CCMD_SND_LISTMIDIDEVICES_EXMP = "";
MANPAGES_CCMD_SND_STATUS_NAME         = "snd_status";
MANPAGES_CCMD_SND_STATUS_DESC         = "Lists information about the current sound device.";
MANPAGES_CCMD_SND_STATUS_EXMP         = "";
MANPAGES_CCMD_SOUNDLINKS_NAME         = "soundlinks";
MANPAGES_CCMD_SOUNDLINKS_DESC         = "Lists the links between different sounds that use the same sound data. Links are generated dynamically while you play, so it is possible for this command to give different results in different games and even at different times during the same game.";
MANPAGES_CCMD_SOUNDLINKS_EXMP         = "";
MANPAGES_CCMD_SOUNDLIST_NAME          = "soundlist";
MANPAGES_CCMD_SOUNDLIST_DESC          = "Lists all the sounds defined and the lumps that they alias to. Unlike regular {{Doom}}, ZDoom refers to sounds using a long name and uses a {{SNDINFO}} lump to map those to the lumps in a WAD file that contain the actual sounds. Logical sounds that refer to the same sound data will have links generated as necessary to avoid actually loading multiple copies of the same sound into memory.";
MANPAGES_CCMD_SOUNDLIST_EXMP          = "";
MANPAGES_CCMD_SPECIAL_NAME            = "special <special> [arg1 [arg2 [arg3 [arg4 [arg5]]]]]";
MANPAGES_CCMD_SPECIAL_DESC            = "Executes an {{action special}} on the current map, optionally passing it up to five numerical arguments.";
MANPAGES_CCMD_SPECIAL_EXMP            = "special thrustthingz 0 30 0 1\tEquivalent of a high jump by calling {{ThrustThingZ( 0, 30, 0, 1 )}}.\nspecial 128 0 30 0 1\t{{128}} is the index for {{ThrustThingZ()}}, so this calls the same as above.\nspecial Sector_SetFriction 0 150\tMake the floor of all sectors on the level with a zero tag (in practice, nearly all of them) more slippery.\nspecial Sector_SetColor 0 255 127 127\tRecolor all sectors with a zero tag to a reddish color using {{Sector_SetColor()}}.";
MANPAGES_CCMD_SPRAY_NAME              = "spray <decal>";
MANPAGES_CCMD_SPRAY_DESC              = "Sprays a {{decal}} on a nearby wall so you can see what it looks like.";
MANPAGES_CCMD_SPRAY_EXMP              = "";
MANPAGES_CCMD_SPYNEXT_NAME            = "spynext";
MANPAGES_CCMD_SPYNEXT_DESC            = "During a {{cooperative}} game or while watching a {{multiplayer}} {{demo}}, this command will switch your view to the next player.";
MANPAGES_CCMD_SPYNEXT_EXMP            = "";
MANPAGES_CCMD_SPYPREV_NAME            = "spyprev";
MANPAGES_CCMD_SPYPREV_DESC            = "During a {{cooperative}} game or while watching a {{multiplayer}} {{demo}}, this command will switch your view to the previous player.";
MANPAGES_CCMD_SPYPREV_EXMP            = "";
MANPAGES_CCMD_STAT_NAME               = "stat [page]";
MANPAGES_CCMD_STAT_DESC               = "Displays profiling information. When used alone, displays a list of available displays. Use one of those as the {{page}} parameter to toggle the display on and off.";
MANPAGES_CCMD_STAT_EXMP               = "";
MANPAGES_CCMD_STOP_NAME               = "stop";
MANPAGES_CCMD_STOP_DESC               = "Stops demo recording and exits the game.";
MANPAGES_CCMD_STOP_EXMP               = "";
MANPAGES_CCMD_STOPMUS_NAME            = "stopmus";
MANPAGES_CCMD_STOPMUS_DESC            = "Stops playing the current song.";
MANPAGES_CCMD_STOPMUS_EXMP            = "";
MANPAGES_CCMD_SUMMON_NAME             = "summon <class> [angle [TID [special [args... ]]]]";
MANPAGES_CCMD_SUMMON_DESC             = "Spawns a new actor in front of you. A complete list of actors can be obtained with the dumpclasses actor command. For a list of actors limited to those you can place in an editor, use the dumpmapthings command. It is possible to spawn actors from another game with this command, but they will not be visible unless you provide the missing graphics for them.\n\nBy default, the actor spawns facing East. If the optional angle parameter is provided, the actor is spawned at an angle relative to the player's current facing instead. (0 faces away from the player, while 180 faces towards him).\n\nAdditional optional parameters can be used to set the summoned actor's {{TID}}, {{special}}, and arguments.";
MANPAGES_CCMD_SUMMON_EXMP             = "summon shotgun\tSpawn a {{Shotgun}} actor.\nsummon hellknight\tSpawn a {{HellKnight}} actor.\nsummon hellknight 0\tSpawn a {{HellKnight}} actor facing away from the player.\nsummon pistol 0 0 120 7 35 0 8 0\tSpawn a {{Pistol}} item that triggers a small earthquake upon pickup. Action special {{120}} means calling {{Radius_Quake}}; with the subsequent arguments it becomes {{Radius_Quake( 7, 35, 0, 8, 0 );}}. The {{angle}} and {{TID}} parameters are not particularly important here, so they are set to \"0\".";
MANPAGES_CCMD_SUMMONFOE_NAME          = "summonfoe <class> [angle [TID [special [args... ]]]]";
MANPAGES_CCMD_SUMMONFOE_DESC          = "Same as summon, but forces monsters created using this command to be hostile to the player, regardless of the actor's {{FRIENDLY}}.";
MANPAGES_CCMD_SUMMONFOE_EXMP          = "";
MANPAGES_CCMD_SUMMONFRIEND_NAME       = "summonfriend <class> [angle [TID [special [args... ]]]]";
MANPAGES_CCMD_SUMMONFRIEND_DESC       = "Same as summon, but causes monsters created using this command to attack non-friendly monsters instead of you.";
MANPAGES_CCMD_SUMMONFRIEND_EXMP       = "";
MANPAGES_CCMD_SUMMONMBF_NAME          = "summonmbf <class> [angle]";
MANPAGES_CCMD_SUMMONMBF_DESC          = "Same as summonfriend, but also gives the summoned actor the {{NOBLOCKMONST}} flag, allowing them to cross monster-blocking lines like MBF friendly monsters do.";
MANPAGES_CCMD_SUMMONMBF_EXMP          = "";
MANPAGES_CCMD_TAKE_NAME               = "take <item> <amount>";
MANPAGES_CCMD_TAKE_DESC               = "Takes an item away from the player. Amount specifies how many to take away (if applicable). Can be used to damage the player by using \"take health X\", where X is the amount of damage to do. If the player reaches 0 health this way, he will die. Use the command printinv for a full list of what is in the player's inventory.";
MANPAGES_CCMD_TAKE_EXMP               = "";
MANPAGES_CCMD_TARGETINV_NAME          = "targetinv";
MANPAGES_CCMD_TARGETINV_DESC          = "Executes \"printinv\" at current crosshair target, listing their inventory items.";
MANPAGES_CCMD_TARGETINV_EXMP          = "";
MANPAGES_CCMD_TEAMLIST_NAME           = "teamlist";
MANPAGES_CCMD_TEAMLIST_DESC           = "Lists the {{teams}} defined in {{TEAMINFO}}.";
MANPAGES_CCMD_TEAMLIST_EXMP           = "";
MANPAGES_CCMD_TESTCOLOR_NAME          = "testcolor <color>";
MANPAGES_CCMD_TESTCOLOR_DESC          = "Sets the {{light color}} of any sectors using the default light to {{color}}. {{color}} can be either a color defined in the {{X11R6RGB}} lump or a color string.";
MANPAGES_CCMD_TESTCOLOR_EXMP          = "";
MANPAGES_CCMD_TESTFADE_NAME           = "testfade <color>";
MANPAGES_CCMD_TESTFADE_DESC           = "Temporarily sets the {{fade color}} of the current level to {{color}}. Most levels fade to black by default, but this can be changed with the MAPINFO lump. {{color}} can be either a color defined in the {{X11R6RGB}} lump or a color string.";
MANPAGES_CCMD_TESTFADE_EXMP           = "";
MANPAGES_CCMD_TESTMUSICVOL_NAME       = "testmusicvol [<volume>]";
MANPAGES_CCMD_TESTMUSICVOL_DESC       = "Allows to change the relative music volume of the current song without changing {{snd_musicvolume}}. The baseline is 1.0. This can be used to test the effect that a {{$musicvolume}} entry for the current song in {{SNDINFO}} would have.";
MANPAGES_CCMD_TESTMUSICVOL_EXMP       = "";
MANPAGES_CCMD_THAW_NAME               = "thaw";
MANPAGES_CCMD_THAW_DESC               = "Clears the PROP_FROZEN and PROP_TOTALLYFROZEN {{properties}} from the player. This is considered a cheat.";
MANPAGES_CCMD_THAW_EXMP               = "";
MANPAGES_CCMD_TIMEDEMO_NAME           = "timedemo";
MANPAGES_CCMD_TIMEDEMO_DESC           = "Plays a demo as fast as the refresh rate will allow and displays the average framerate attained during playback. Due to limitations in the current demo system, this command will also exit the game when the demo finishes.";
MANPAGES_CCMD_TIMEDEMO_EXMP           = "";
MANPAGES_CCMD_TOGGLE_NAME             = "toggle <cvar>";
MANPAGES_CCMD_TOGGLE_DESC             = "Toggles the value of {{cvar}} between false and true (zero and  non-zero).";
MANPAGES_CCMD_TOGGLE_EXMP             = "";
MANPAGES_CCMD_TOGGLECONSOLE_NAME      = "toggleconsole";
MANPAGES_CCMD_TOGGLECONSOLE_DESC      = "Toggles display of the {{console}} on/off.";
MANPAGES_CCMD_TOGGLECONSOLE_EXMP      = "";
MANPAGES_CCMD_TOGGLEMAP_NAME          = "togglemap";
MANPAGES_CCMD_TOGGLEMAP_DESC          = "Press to active the {{automap}}. Press again to return to the game. If {{am_overlay}} is true, this is also used toggle the overlay map.";
MANPAGES_CCMD_TOGGLEMAP_EXMP          = "";
MANPAGES_CCMD_TOGGLEMESSAGES_NAME     = "togglemessages";
MANPAGES_CCMD_TOGGLEMESSAGES_DESC     = "Toggles display of game messages on/off. The only difference between doing this and \"{{toggle}} {{show_messages}}\" is that this command always displays a message describing the current state of messages.";
MANPAGES_CCMD_TOGGLEMESSAGES_EXMP     = "";
MANPAGES_CCMD_TOGGLESCOREBOARD_NAME   = "togglescoreboard";
MANPAGES_CCMD_TOGGLESCOREBOARD_DESC   = "Toggles the display of the {{scoreboard}} on and off.";
MANPAGES_CCMD_TOGGLESCOREBOARD_EXMP   = "";
MANPAGES_CCMD_TURN180_NAME            = "turn180";
MANPAGES_CCMD_TURN180_DESC            = "Instantly turns the player 180 degrees, reversing his facing.";
MANPAGES_CCMD_TURN180_EXMP            = "";
MANPAGES_CCMD_TURNSPEEDS_NAME         = "turnspeeds [speed1 [speed2 [speed3 [speed4]]]]";
MANPAGES_CCMD_TURNSPEEDS_DESC         = "Controls how quickly you turn with the keyboard. Using this command without any parameters lists the current turning speeds. To set the speeds, specify at least one, and any you do not specify will be filled in automatically. The different speeds are used in the following situations:\n- Turning while walking\n- Turning while running\n- Just started turning while walking\n- Just started turning while running";
MANPAGES_CCMD_TURNSPEEDS_EXMP         = "";
MANPAGES_CCMD_UNBIND_NAME             = "unbind <key>";
MANPAGES_CCMD_UNBIND_DESC             = "Removes a binding from the specified key.";
MANPAGES_CCMD_UNBIND_EXMP             = "";
MANPAGES_CCMD_UNBINDALL_NAME          = "unbindall";
MANPAGES_CCMD_UNBINDALL_DESC          = "Removes all bindings and doublebindings from every key. To restore the default bindings, you can use the binddefaults command. {{Caution: there is no way to restore any custom bindings after issuing this command except by retyping each bind command or using the controls setup menu.}}";
MANPAGES_CCMD_UNBINDALL_EXMP          = "";
MANPAGES_CCMD_UNDOUBLEBIND_NAME       = "undoublebind <key>";
MANPAGES_CCMD_UNDOUBLEBIND_DESC       = "Removes a doublebinding from the specified key.";
MANPAGES_CCMD_UNDOUBLEBIND_EXMP       = "";
MANPAGES_CCMD_UNMAPBIND_NAME          = "unmapbind <key>";
MANPAGES_CCMD_UNMAPBIND_DESC          = "Removes a mapbinding from the specified key.";
MANPAGES_CCMD_UNMAPBIND_EXMP          = "";
MANPAGES_CCMD_UNSET_NAME              = "unset <CVAR>";
MANPAGES_CCMD_UNSET_DESC              = "Undefines a user-created CVAR.";
MANPAGES_CCMD_UNSET_EXMP              = "";
MANPAGES_CCMD_USE_NAME                = "use <item>";
MANPAGES_CCMD_USE_DESC                = "Uses an item of class type <item>, if present in the player's inventory.  If the item is not present, nothing happens.  For correct activation of {{Hexen}}'s {{flechettes}} from the console, see {{useflechette}} below.";
MANPAGES_CCMD_USE_EXMP                = "";
MANPAGES_CCMD_USEFLECHETTE_NAME       = "useflechette";
MANPAGES_CCMD_USEFLECHETTE_DESC       = "{{Hexen}}'s {{flechettes}} require special handling due to the actual item in the inventory being different depending on the player class picking them up.  This command uses a flechette of the type corresponding to the player class, if present in the player's inventory. If the player has no flechettes in their inventory, nothing happens.";
MANPAGES_CCMD_USEFLECHETTE_EXMP       = "";
MANPAGES_CCMD_UTID_NAME               = "utid [start [limit]]";
MANPAGES_CCMD_UTID_DESC               = "Prints an unused {{TID}}. If start is 0 or omitted, then a random TID will be chosen. Otherwise, it will perform a linear search starting from  start_tid. If limit is given and non-0, then it will not check more than <limit> number of TIDs. Prints 0 if no suitable TID was found.";
MANPAGES_CCMD_UTID_EXMP               = "";
MANPAGES_CCMD_VID_LISTADAPTERS_NAME   = "vid_listadapters";
MANPAGES_CCMD_VID_LISTADAPTERS_DESC   = "Prints a list of all video adapters available. This command only works with either the {{ZDoom}} {{Direct3D}} renderer or the {{GZDoom}}/{{Zandronum}} {{OpenGL}} renderer. Choosing which adapter to use can be done by setting the value of the {{vid_adapter}} {{console variable}}.";
MANPAGES_CCMD_VID_LISTADAPTERS_EXMP   = "";
MANPAGES_CCMD_WARP_NAME               = "warp <x-coord> <y-coord> [z-coord]";
MANPAGES_CCMD_WARP_DESC               = "Sends you to the specified coordinates immediately. This can be used with {{idmypos}} to debug problems in a specific area of a map.";
MANPAGES_CCMD_WARP_EXMP               = "";
MANPAGES_CCMD_WDIR_NAME               = "wdir <archive>";
MANPAGES_CCMD_WDIR_DESC               = "Lists the contents of a loaded wad file or other archive.";
MANPAGES_CCMD_WDIR_EXMP               = "";
MANPAGES_CCMD_WEAPDROP_NAME           = "weapdrop";
MANPAGES_CCMD_WEAPDROP_DESC           = "Drops the currently selected {{weapon}}.";
MANPAGES_CCMD_WEAPDROP_EXMP           = "";
MANPAGES_CCMD_WEAPNEXT_NAME           = "weapnext";
MANPAGES_CCMD_WEAPNEXT_DESC           = "Selects the next {{weapon}} (in order) that you own and have {{ammo}} for. In addition, it plays the \"misc/weaponchange\" sound if defined. By default it is not.";
MANPAGES_CCMD_WEAPNEXT_EXMP           = "";
MANPAGES_CCMD_WEAPONSECTION_NAME      = "weaponsection <ini section>";
MANPAGES_CCMD_WEAPONSECTION_DESC      = "This command is similar to {{addkeysection}}. Upon execution, it loads all the weapon slot assignments from the corresponding section in {{zdoom.ini}}. When you quit the game, the weapon slots will also be stored in the specified section in zdoom.ini instead of their standard location so that they do not overwrite the player's normal weapon assignments.";
MANPAGES_CCMD_WEAPONSECTION_EXMP      = "";
MANPAGES_CCMD_WEAPPREV_NAME           = "weapprev";
MANPAGES_CCMD_WEAPPREV_DESC           = "Selects the previous {{weapon}} (in order) that you own and have {{ammo}} for. In addition, it plays the \"misc/weaponchange\" sound if defined. By default it is not.";
MANPAGES_CCMD_WEAPPREV_EXMP           = "";
MANPAGES_CCMD_WHEREISINI_NAME         = "whereisini";
MANPAGES_CCMD_WHEREISINI_DESC         = "Prints the location of the current {{zdoom.ini}} to the console. The zdoom.ini file is normally stored in the user's profile directory. It may not be immediately obvious where that is, so you can use this command to find out.";
MANPAGES_CCMD_WHEREISINI_EXMP         = "";
MANPAGES_CCMD_ANGLECONVTEST_NAME      = "angleconvtest";
MANPAGES_CCMD_ANGLECONVTEST_DESC      = "Internal test of angle conversion to different data types.\n- Original angle: (double) ang;\n- Obtaining DAngle::fromDeg(ang).BAMs();\n- Casting to unsigned via (unsigned)(ang * (0x40000000 / 90.));\n- Casting to signed via (unsigned)(int)(ang * (0x40000000 / 90.)).";
MANPAGES_CCMD_ANGLECONVTEST_EXMP      = "";
MANPAGES_CCMD_BENCH_NAME              = "bench";
MANPAGES_CCMD_BENCH_DESC              = "Run a hardware rendering benchmark (performance analysis) for five seconds. Upon completion, a \"benchmarks.txt\" file will be created (or updated) in the game's startup directory with a snapshot of the information obtained during those five seconds.";
MANPAGES_CCMD_BENCH_EXMP              = "";
MANPAGES_CCMD_CACHESOUND_NAME         = "cachesound <sound> ...";
MANPAGES_CCMD_CACHESOUND_DESC         = "Forcefully caches the specified sound(s). Sound lookup is performed by logical name.";
MANPAGES_CCMD_CACHESOUND_EXMP         = "cachesound menu/activate menu/dismiss menu/clear\tCache the three specified sounds.";
MANPAGES_CCMD_CHANGESKILL_NAME        = "changeskill <skill>";
MANPAGES_CCMD_CHANGESKILL_DESC        = "Changes the {{skill level}}, and unlike the \"{{skill}}\" variable, applies it starting from the next level, rather than from a new game. Numbering starts from zero, and \"0\" usually corresponds to the easiest skill level. In original Doom, level \"4\" corresponds to \"Nightmare!\" difficulty.";
MANPAGES_CCMD_CHANGESKILL_EXMP        = "For Doom and Doom 2:\nchangeskill 0\t\"I'm too young to die.\"\nchangeskill 1\t\"Hey, not too rough.\"\nchangeskill 2\t\"Hurt me plenty.\"\nchangeskill 3\t\"Ultra-Violence.\"\nchangeskill 4\t\"Nightmare!\" ";
MANPAGES_CCMD_CLEAR_NAME              = "clear";
MANPAGES_CCMD_CLEAR_DESC              = "Clears the in-game console buffer, i.e., removes all lines, making it empty. This does not affect output via the {{logfile}} command or via stdout redirection.";
MANPAGES_CCMD_CLEAR_EXMP              = "";
MANPAGES_CCMD_CLEARNODECACHE_NAME     = "clearnodecache";
MANPAGES_CCMD_CLEARNODECACHE_DESC     = "Clears all cached GL nodes.";
MANPAGES_CCMD_CLEARNODECACHE_EXMP     = "";
MANPAGES_CCMD_CONTROLPRESET_NAME      = "controlpreset <keyboard_layout>";
MANPAGES_CCMD_CONTROLPRESET_DESC      = "Sets one of the predefined {{keyboard layouts}} for the game. Values and their order may vary from version to version; you can see the valid names under \"Options\" -> \"Customize Controls\" -> \"Keyboard Layout\".";
MANPAGES_CCMD_CONTROLPRESET_EXMP      = "controlpreset 0\tClassic ZDoom layout.";
MANPAGES_CCMD_CREATEENVIRONMENT_NAME  = "createenvironment";
MANPAGES_CCMD_CREATEENVIRONMENT_DESC  = "Internal command for creating a new reverb environment, primarily used in the {{reverbedit}} menu. There is no point in using it manually from the console, as it depends on the variables reverbedit_name, reverbedit_id1, and reverbedit_id2, which are protected from direct writing.";
MANPAGES_CCMD_CREATEENVIRONMENT_EXMP  = "";
MANPAGES_CCMD_CURRENTMUSIC_NAME       = "currentmusic";
MANPAGES_CCMD_CURRENTMUSIC_DESC       = "Displays the name of the current music track. Alternative to the {{changemus}} command without parameters.";
MANPAGES_CCMD_CURRENTMUSIC_EXMP       = "";
MANPAGES_CCMD_CVARSEARCH_NAME         = "cvarsearch <glob>";
MANPAGES_CCMD_CVARSEARCH_DESC         = "Same as {{cvarlist}}, but displays search results for all CVars by mask. Wildcards \"*\" and \"?\" are supported.";
MANPAGES_CCMD_CVARSEARCH_EXMP         = "cvarsearch coop\tWill output all CVars that include the word \"coop\".\ncvarsearch coop*ammo\tAll CVars that include the word \"coop\", followed somewhere later by the word \"ammo\".\ncvarsearch vid_\tAll CVars containing the substring \"vid_\".\ncvarsearch vid_*scale*\tAll CVars containing the substring \"vid_\", followed somewhere later by the substring \"scale\".\ncvarsearch gl_??????map\tAll CVars containing the substring \"gl_\", followed by 6 any characters, then the substring \"map\".";
MANPAGES_CCMD_DEBUG_RESTART_NAME      = "debug_restart";
MANPAGES_CCMD_DEBUG_RESTART_DESC      = "Restarts the engine, used for debugging. When using this command, many basic arguments affecting the game are removed, including loaded files (\"-file\"), selected IWAD (\"-iwad\"), game mode (such as \"-deathmatch\"), skill level (\"-skill\"), and so on. However, the autoload section from the *.ini file is still executed.";
MANPAGES_CCMD_DEBUG_RESTART_EXMP      = "";
MANPAGES_CCMD_DUMP3DF_NAME            = "dump3df <sector>";
MANPAGES_CCMD_DUMP3DF_DESC            = "Displays technical information about 3D floors associated with the specified sector. Information includes height and the floor/ceiling model, flags, and transparency. If the sector has no 3D floors, the command will output nothing.";
MANPAGES_CCMD_DUMP3DF_EXMP            = "";
MANPAGES_CCMD_DUMPLINKTABLE_NAME      = "dumplinktable"; // In theory, this command will print all the portals' displacement. In practice, it's not. I have checked for about ten projects with different portals, and CCMD output in all of them is empty. Tested with LZDoom, GZDoom, and newest UZDoom; ZDoom haven't had this CCMD yet.
MANPAGES_CCMD_DUMPLINKTABLE_DESC      = "Displays portal displacements. If a portal is indirect, its color in the output will be different.";
MANPAGES_CCMD_DUMPLINKTABLE_EXMP      = "";
MANPAGES_CCMD_DUMPTAGS_NAME           = "dumptags";
MANPAGES_CCMD_DUMPTAGS_DESC           = "Outputs a complete list of tags for sectors and lines. Can be quite bulky for large levels.";
MANPAGES_CCMD_DUMPTAGS_EXMP           = "";
MANPAGES_CCMD_EVAL_NAME               = "eval <expression> [variable]";
MANPAGES_CCMD_EVAL_DESC               = "Evaluates a mathematical {{expression}} and either prints it to the console or stores it in a {{console variable}}. Also see CCMD {{test}}.\n\nWhen accessing {{CVARs}} from within the expression, you must prefix them with a dollar sign ($). Expressions for {{eval}} and {{test}} are written using prefix notation instead of the more common infix notation. Basically, you first specify what you want to do (the operator) and then what you want to do it to (the operands). You must separate operators and operands with spaces. The list of includes:\n- Arithmetics: \"+ a b\", \"- a b\", \"* a b\", \"/ a b\" (division), \"% a b\" (reminder) and \"^ a b\" (raise {{a}} to the {{b}}-th power).\n- Comparison: \"< a b\", \"<= a b\", \"> a b\", \">= a b\", \"= a b\" (equality, also \"== a b\"), \"!= a b\" (inequality, also \"<> a b\"). Result is \"1\" (if evalutes to true) or \"0\" (if false).\n- Bit-wise: \"& a b\" (AND), \"| a b\" (OR), \"xor a b\" (exclusive OR).\n- Logical: \"&& a b\" (logical AND), \"|| a b\" (logical OR).";
MANPAGES_CCMD_EVAL_EXMP               = "eval + 2 2\tComputes 2 + 2.\neval - 5 3\tComputes 5 - 3.\neval + 2 * 5 6\tComputes 2 + (5 * 6).\neval - $screenblocks 1 screenblocks\tDecreases the number of {{screenblocks}}.\neval + % $i_timescale 1 0.25 i_timescale\tCycles {{i_timescale}} between values \"0.25\", \"0.5\", \"0.75\" and \"1\".";
MANPAGES_CCMD_EVENT_NAME              = "event <name> [arg1] [arg2] [arg3]";
MANPAGES_CCMD_EVENT_DESC              = "Send a Console Event with the specified {{name}} and, if required, numeric {{arguments 1-3}}. Related to the {{netevent}} and {{interfaceevent}} commands.";
MANPAGES_CCMD_EVENT_EXMP              = "event myevent 44\tSend console event \"myevent\" with one argument \"44\".\nevent \"Data with spaces\"\tSend console event \"Data with spaces\" without arguments.";
MANPAGES_CCMD_EXIT_NAME               = "exit";
MANPAGES_CCMD_EXIT_DESC               = "Exit the game. Same as the {{quit}} command.";
MANPAGES_CCMD_EXIT_EXMP               = "";
MANPAGES_CCMD_FFCF_NAME               = "ffcf";
MANPAGES_CCMD_FFCF_DESC               = "Displays technical information about the sectors the player is currently associated with and the lines it cross.";
MANPAGES_CCMD_FFCF_EXMP               = "";
MANPAGES_CCMD_FLUSHTEXTURES_NAME      = "flushtextures";
MANPAGES_CCMD_FLUSHTEXTURES_DESC      = "Resets all textures dependent on the rendering type. Can be used, for example, to clear redundant information when switching from a Software renderer to a GPU.";
MANPAGES_CCMD_FLUSHTEXTURES_EXMP      = "";
MANPAGES_CCMD_FS_DIR_NAME             = "fs_dir";
MANPAGES_CCMD_FS_DIR_DESC             = "A complete dump of all loaded files. Column list: full path to the file, short file name, resource ID, size in bytes, container (archive/path/*.wad file). Hidden files, as well as files inside *.wad, are indicated in red with an \"(h)\" suffix at the end.";
MANPAGES_CCMD_FS_DIR_EXMP             = "";
MANPAGES_CCMD_GC_NAME                 = "gc <stop|now|full|count|pause [size]|stepmul [size]>";
MANPAGES_CCMD_GC_DESC                 = "Basic control of the memory garbage collector. See also \"{{stat gc}}\".";
MANPAGES_CCMD_GC_EXMP                 = "gc stop\tPauses the collector.\ngc now\tForcefully compels the GC to delete all unneeded objects from memory.\ngc count\tDisplays the number of tracked objects.";
MANPAGES_CCMD_GETDATE_NAME            = "getdate";
MANPAGES_CCMD_GETDATE_DESC            = "Retrieve the current date. If the {{setdate}} command has not been used previously, the actual date of the computer running the game will be displayed.";
MANPAGES_CCMD_GETDATE_EXMP            = "";
MANPAGES_CCMD_INTERFACEEVENT_NAME     = "interfaceevent <name> [arg1] [arg2] [arg3]";
MANPAGES_CCMD_INTERFACEEVENT_DESC     = "Send an Interface Event with the specified {{name}} and, if required, numeric {{arguments 1-3}}. Related to the {{netevent}} and {{event}} commands.";
MANPAGES_CCMD_INTERFACEEVENT_EXMP     = "interfaceevent myevent 44\tSend interface event \"myevent\" with one argument \"44\".\ninterfaceevent \"Data with spaces\"\tSend interface event \"Data with spaces\" without arguments.";
MANPAGES_CCMD_LISTCVARSWITHOUTDESCRIPTION_NAME = "listcvarswithoutdescription";
MANPAGES_CCMD_LISTCVARSWITHOUTDESCRIPTION_DESC = "Outputs a list of only the names of all CVars, one per line.";
MANPAGES_CCMD_LISTCVARSWITHOUTDESCRIPTION_EXMP = "";
MANPAGES_CCMD_LISTSHADERS_NAME        = "listshaders";
MANPAGES_CCMD_LISTSHADERS_DESC        = "Outputs a list of all post-processing shaders.";
MANPAGES_CCMD_LISTSHADERS_EXMP        = "";
MANPAGES_CCMD_LISTTEXTUREALIASES_NAME = "listtexturealiases";
MANPAGES_CCMD_LISTTEXTUREALIASES_DESC = "Outputs a list of all texture aliases.";
MANPAGES_CCMD_LISTTEXTUREALIASES_EXMP = "";
MANPAGES_CCMD_LISTUNIFORMS_NAME       = "listuniforms <shader>";
MANPAGES_CCMD_LISTUNIFORMS_DESC       = "Outputs a list of all uniform variables for the specified {{shader}}.";
MANPAGES_CCMD_LISTUNIFORMS_EXMP       = "";
MANPAGES_CCMD_LOAD_NAME               = "load <filename>";
MANPAGES_CCMD_LOAD_DESC               = "Loads a game from the specified file (the \".zds\" extension is optional). The save file directory is taken from the {{save_dir}} variable or, if it is empty, from the default path. The current save path can be checked via the {{opensaves}} command. Loading from an absolute path is prohibited.";
MANPAGES_CCMD_LOAD_EXMP               = "load auto02\tLoads the game from the file {{auto02.zds}}.\nload ../../save.zds\tA way to load a file from another location via a relative path.";
MANPAGES_CCMD_MEASUREINTERMISSIONS_NAME = "measureintermissions";
MANPAGES_CCMD_MEASUREINTERMISSIONS_DESC = "Output the sizes of intermission screen texts, such as \"E1TEXT\", \"HE2TEXT\", \"T3TEXT\", and \"TXT_HEXEN_CLUS4MSG\". The search is performed across all known languages.";
MANPAGES_CCMD_MEASUREINTERMISSIONS_DESC = "Output the sizes of intermission screen texts, such as \"E1TEXT\", \"HE2TEXT\", \"T3TEXT\" and \"TXT_HEXEN_CLUS4MSG\". Search is performed across all known languages.";
MANPAGES_CCMD_MEASUREINTERMISSIONS_EXMP = "";
MANPAGES_CCMD_MENUCONSOLE_NAME        = "menuconsole";
MANPAGES_CCMD_MENUCONSOLE_DESC        = "Remove all menus and toggle the console state. When entered from the console, it is analogous to calling {{toggleconsole}}.";
MANPAGES_CCMD_MENUCONSOLE_DESC        = "Remove all menus and toggle console state. When entered from the console, equivalent to calling {{toggleconsole}}.";
MANPAGES_CCMD_MENUCONSOLE_EXMP        = "";
MANPAGES_CCMD_MENU_RESOLUTION_COMMIT_CHANGES_NAME = "menu_resolution_commit_changes";
MANPAGES_CCMD_MENU_RESOLUTION_COMMIT_CHANGES_DESC = "Apply values specified via {{menu_resolution_set_custom}} as screen width and height. This command is not intended for manual invocation.";
MANPAGES_CCMD_MENU_RESOLUTION_COMMIT_CHANGES_EXMP = "";
MANPAGES_CCMD_MENU_RESOLUTION_SET_CUSTOM_NAME = "menu_resolution_set_custom <x> <y>";
MANPAGES_CCMD_MENU_RESOLUTION_SET_CUSTOM_DESC = "Set the values for {{menu_resolution_custom_width}} and {{menu_resolution_custom_height}} (screen width and height, {{x}} and {{y}}, respectively). To apply, the {{menu_resolution_commit_changes}} command must be called. This command is not intended for manual invocation.";
MANPAGES_CCMD_MENU_RESOLUTION_SET_CUSTOM_EXMP = "menu_resolution_set_custom 1920 1080\tSet the emulated screen resolution to FullHD.";
MANPAGES_CCMD_MESSAGEMODE2_NAME       = "messagemode2";
MANPAGES_CCMD_MESSAGEMODE2_DESC       = "Switch to message typing mode for your team during teamplay ({{teamplay}} variable). From the console, it may be more convenient to use {{say_team}}.";
MANPAGES_CCMD_MESSAGEMODE2_EXMP       = "";
MANPAGES_CCMD_NETEVENT_NAME           = "netevent <name> [arg1] [arg2] [arg3]";
MANPAGES_CCMD_NETEVENT_DESC           = "Send a Network Event with the specified {{name}} and, if required, numeric {{arguments 1-3}}. Related to the {{event}} and {{interfaceevent}} commands.";
MANPAGES_CCMD_NETEVENT_EXMP           = "netevent myevent 44\tSend network event \"myevent\" with one argument \"44\".\nnetevent \"Data with spaces\"\tSend network event \"Data with spaces\" without arguments.";
MANPAGES_CCMD_OPENCONFIG_NAME         = "openconfig";
MANPAGES_CCMD_OPENCONFIG_DESC         = "Open the directory containing the game configuration.";
MANPAGES_CCMD_OPENCONFIG_EXMP         = "";
MANPAGES_CCMD_OPENSAVES_NAME          = "opensaves";
MANPAGES_CCMD_OPENSAVES_DESC          = "Open the directory containing the game saves.";
MANPAGES_CCMD_OPENSAVES_EXMP          = "";
MANPAGES_CCMD_OPENSCREENSHOTS_NAME    = "openscreenshots";
MANPAGES_CCMD_OPENSCREENSHOTS_DESC    = "Open the directory containing the game screenshots.";
MANPAGES_CCMD_OPENSCREENSHOTS_EXMP    = "";
MANPAGES_CCMD_PREVMENU_NAME           = "prevmenu";
MANPAGES_CCMD_PREVMENU_DESC           = "Go to the menu one level up. The command is not applicable for manual input in the console.";
MANPAGES_CCMD_PREVMENU_EXMP           = "";
MANPAGES_CCMD_PRINTLOCALIZED_NAME     = "printlocalized <str> [lang]";
MANPAGES_CCMD_PRINTLOCALIZED_DESC     = "Print the {{str}} in the specified {{lang}} according to the localization table. The \"$\" symbol at the beginning of the word is implied automatically. {{Lang}} can consist of two or three characters, and if not specified, the current locale is used.";
MANPAGES_CCMD_PRINTLOCALIZED_EXMP     = "printlocalized c2text\tPrint {{$C2TEXT}} (the text screen at the end of Doom 2's second episode) in the current locale.\nprintlocalized c2text es\tPrint {{$C2TEXT}} in Spanish.\nprintlocalized gotarmor eng\tPrint {{$GOTARMOR}} in the British English dialect.";
MANPAGES_CCMD_PRINTSECTIONS_NAME      = "printsections"; // Same as for `dumplinktable`. It should work, but it won't. First appear in GZDoom.
MANPAGES_CCMD_PRINTSECTIONS_DESC      = "Prints list of sections and segs for the level.";
MANPAGES_CCMD_PRINTSECTIONS_EXMP      = "";
MANPAGES_CCMD_PROFILETHINKERS_NAME    = "profilethinkers <sort> [limit]";
MANPAGES_CCMD_PROFILETHINKERS_DESC    = "Profiling of Thinker class objects - gathering information about world object processing speed - is used to determine the slowest parts of the code. Profiling is launched for all world objects on the next game tick (i.e., you need to close the console). As a result, a list is output in {{sort}} order, with no more than {{limit}} rows if the limit is specified. {{Sort}} can be performed in eight ways:\n {{class}}, {{+c}} or {{1}} - by class name, ascending, \"A\" at the top.\n{{-class}}, {{-c}} or {{2}} - by class name, descending, \"Z\" at the top.\n {{#}}, {{+#}} or {{3}}     - by number of objects, ascending, minimum at the top.\n{{-#}} or {{4}}         - by number of objects, descending.\n {{avg}}, {{+a}} or {{5}}   - by average time, ascending, minimum at the top.\n{{-avg}}, {{-a}} or {{6}}   - by average time, descending.\n {{total}}, {{+t}} or {{7}} - by total time, ascending, minimum at the top. This variant is used most often.\n{{-total}}, {{-t}} or {{8}} - by total time, descending.\n\nAll times are specified in milliseconds. Average time is equal to the total time divided by the number of objects.";
MANPAGES_CCMD_PROFILETHINKERS_EXMP    = "profilethinkers 7\tStart profiling sorted by total time. Allows a quick estimate of whether the issue is complex code or a large number of objects.\nprofilethinkers -# 15\tAfter profiling, keep only 15 rows of the most frequent objects.\nprofilethinkers avg\tProfiling sorted by average time per object.";
MANPAGES_CCMD_QUICKLOAD_NAME          = "quickload";
MANPAGES_CCMD_QUICKLOAD_DESC          = "Invoke the quickload dialog, similar to pressing {{F9}} with default keyboard settings.";
MANPAGES_CCMD_QUICKLOAD_EXMP          = "";
MANPAGES_CCMD_QUICKSAVE_NAME          = "quicksave";
MANPAGES_CCMD_QUICKSAVE_DESC          = "Invoke the quicksave dialog, similar to pressing {{F6}} with default keyboard settings.";
MANPAGES_CCMD_QUICKSAVE_EXMP          = "";
MANPAGES_CCMD_QUIT_NAME               = "quit";
MANPAGES_CCMD_QUIT_DESC               = "Exit the game. Same as the {{exit}} command.";
MANPAGES_CCMD_QUIT_EXMP               = "";
MANPAGES_CCMD_RESETB2DEFAULTS_NAME    = "resetb2defaults";
MANPAGES_CCMD_RESETB2DEFAULTS_DESC    = "Reset key bindings for actions to their defaults. The {{reset2defaults}} command includes this action.";
MANPAGES_CCMD_RESETB2DEFAULTS_EXMP    = "";
MANPAGES_CCMD_REVERBEDIT_NAME         = "reverbedit";
MANPAGES_CCMD_REVERBEDIT_DESC         = "Open the reverb environment settings menu.";
MANPAGES_CCMD_REVERBEDIT_EXMP         = "";
MANPAGES_CCMD_REVERTENVIRONMENT_NAME  = "revertenvironment";
MANPAGES_CCMD_REVERTENVIRONMENT_DESC  = "Internal command to revert changes in the reverb environment, primarily needed in the {{reverbedit}} menu. Manually, from the console, there is no point in using it; it depends on the variables reverbedit_name, reverbedit_id1 and reverbedit_id2, which are protected from direct writing.";
MANPAGES_CCMD_REVERTENVIRONMENT_EXMP  = "";
MANPAGES_CCMD_RNGSEED_NAME            = "rngseed (get|clear|set <value>)";
MANPAGES_CCMD_RNGSEED_DESC            = "Control the initial value (seed) of the random number generator. The {{get}} keyword outputs the current generation seed to the console; {{set}} sets a new static generation seed; {{clear}} resets it. It is important to note that setting or resetting the value will only be applied starting from a new game.";
MANPAGES_CCMD_RNGSEED_EXMP            = "rngseed set 1234\tSet the random number generator seed to {{1234}}.\nrngseed clear\tRemove the set seed. The next game will start with a different initial value.";
MANPAGES_CCMD_R_SHOWCAPS_NAME         = "r_showcaps";
MANPAGES_CCMD_R_SHOWCAPS_DESC         = "Show the list of capabilities of the current renderer.";
MANPAGES_CCMD_R_SHOWCAPS_EXMP         = "";
MANPAGES_CCMD_SAVE_NAME               = "save <filename> [description]";
MANPAGES_CCMD_SAVE_DESC               = "Save the game to the file {{filename}} (the \".zds\" extension is optional) with the header {{description}}. The directory for save files is taken from the {{save_dir}} variable or, if empty, from the default path. The current save path can be checked via the {{opensaves}} command. Saving to an absolute path is prohibited.";
MANPAGES_CCMD_SAVE_EXMP               = "save extra1\tSaves the game to the file {{extra1.zds}}.\nsave doom2map16.zds \"Doom 2, Suburbs\"\tSaves the game to the file {{doom2map16.zds}} with the header \"Doom 2, Suburbs\".\nsave ../../save.zds\tA way to save a file to another location via a relative path.";
MANPAGES_CCMD_SAVEREVERBS_NAME        = "savereverbs";
MANPAGES_CCMD_SAVEREVERBS_DESC        = "Internal command to write all changes from the reverb editor to the configuration file. Primarily used in the {{reverbedit}} menu.";
MANPAGES_CCMD_SAVEREVERBS_EXMP        = "";
MANPAGES_CCMD_SELECTENVIRONMENT_NAME  = "selectenvironment";
MANPAGES_CCMD_SELECTENVIRONMENT_DESC  = "Internal command for selecting an existing reverb environment, primarily used in the {{reverbedit}} menu. There is no point in using it manually from the console, as it depends on the variables reverbedit_name, reverbedit_id1, and reverbedit_id2, which are protected from direct writing.";
MANPAGES_CCMD_SELECTENVIRONMENT_EXMP  = "";
MANPAGES_CCMD_SETDATE_NAME            = "setdate <HH:MM:SS DD-MM-YYYY>";
MANPAGES_CCMD_SETDATE_DESC            = "Setting the date-time emulation within the engine to the specified value in the \"HOURS:MINUTES:SECONDS DAY-MONTH-YEAR\" format (syntax is mandatory: two colons, a space, and two hyphens). You can retrieve the current value via the {{getdate}} command. Does not affect the real time of the operating system.";
MANPAGES_CCMD_SETDATE_EXMP            = "setdate 21:33:07 31-12-2000\tJust a few hours away from the New Year of the new millennium!";
MANPAGES_CCMD_SETINV_NAME             = "setinv <inventory> <amount> [overlimit]";
MANPAGES_CCMD_SETINV_DESC             = "Set the number of inventory {{items}} exactly to the specified {{amount}}. If the {{overlimit}} parameter is set to \"1\", the setting will ignore the inventory item maximum. You can also use the keyword \"health\" in place of {{item}}, which sets the player's health amount.\n\nPlease note that in some versions this command is broken and may cause the game to crash! Related commands are {{give}} and {{take}}.";
MANPAGES_CCMD_SETINV_EXMP             = "setinv clip 100\tSet the amount of {{clip}} exactly to 100 items.\nsetinv health 999 1\tSet the player's health to 999 points (regardless of whether there is a limit of 100/200 units).";
MANPAGES_CCMD_SETREPLAYGAIN_NAME      = "setreplaygain <dB>";
MANPAGES_CCMD_SETREPLAYGAIN_DESC      = "Music gain, in dB (allowable values from 0.0 to 10.0). Without a parameter, outputs the current gain. Requires an active playlist?";
MANPAGES_CCMD_SETREPLAYGAIN_EXMP      = "";
MANPAGES_CCMD_SHADERENABLE_NAME       = "shaderenable <name> <1|0|-1>";
MANPAGES_CCMD_SHADERENABLE_DESC       = "Enabling or disabling the shader {{name}}. A value of \"1\" enables the shader, \"0\" disables it, and \"-1\" toggles it.";
MANPAGES_CCMD_SHADERENABLE_EXMP       = "shaderenable myshader 1\tEnable the shader {{myshader}}.";
MANPAGES_CCMD_SHADERUNIFORM_NAME      = "shaderuniform <shader> <uniform> [val1 [val2 [val3]]]";
MANPAGES_CCMD_SHADERUNIFORM_DESC      = "Read or set a uniform {{variable}} for the specified {{shader}}. If there are no {{values 1-3}}, the current values of the variable are displayed. All unspecified values become \"0.0\".";
MANPAGES_CCMD_SHADERUNIFORM_EXMP      = "shaderuniform myshader somevec\tOutput the value of the uniform variable {{somevec}} in shader {{myshader}}.\nshaderuniform myshader e 2.71\tSet the value of the uniform variable {{myshader.e}} to \"2.71\".\nshaderuniform myshader vec3 2.71\tSet the value of the uniform variable {{myshader.vec3}} to \"(2.71, 0.0, 0.0)\".\nshaderuniform myshader vec3 1 2 3\tSet the value of the uniform variable {{myshader.vec3}} to \"(1.0, 2.0, 3.0)\".";
MANPAGES_CCMD_SND_RESET_NAME          = "snd_reset";
MANPAGES_CCMD_SND_RESET_DESC          = "Restarts the engine's sound subsystem.";
MANPAGES_CCMD_SND_RESET_EXMP          = "";
MANPAGES_CCMD_SPYCANCEL_NAME          = "spycancel";
MANPAGES_CCMD_SPYCANCEL_DESC          = "Return to your own body when viewing from another player's perspective in multiplayer.";
MANPAGES_CCMD_SPYCANCEL_EXMP          = "";
MANPAGES_CCMD_TEST_NAME               = "test <expression> <true-command> [<false-command>]";
MANPAGES_CCMD_TEST_DESC               = "Evaluates {{expression}} and executes {{true-command}} if the result is non-zero. If the result is zero, then {{false-command}} will be executed instead (if you specified it).\n\n{{Expression}} syntax is similar to the {{eval}} command. Note that {{command}}s should be wrapped in {{\"}}quotes{{\"}} if they have any arguments. CCMD {{alias}} can be useful with long input in {{command}}s.";
MANPAGES_CCMD_TEST_EXMP               = "test 0 kill \"echo False!\"\tMake sure that \"0\" will trigger the second command (or be instantly killed).\ntest 1 \"echo True!\" kill\tMake sure that any non-zero result will trigger the first command (or be instantly killed).\ntest = + 2 2 4 \"echo 2+2 really is 4\"\tVerify that ZDoom performs basic additions correctly. There's no {{false-command}}.\n\ntest $cl_run \"echo Running by default\" \"echo Calm\"\tPrint different messages depending on whether autorun is on or off.\n\ntest <= $screenblocks 10 \"echo Screenblocks: $screenblocks\" \"echo The view window is full size\"\tPrint different messages depending on the expression.";
MANPAGES_CCMD_TESTCUTSCENE_NAME       = "testcutscene <buildfunction>";
MANPAGES_CCMD_TESTCUTSCENE_DESC       = "Starts the specified cutscene.";
MANPAGES_CCMD_TESTCUTSCENE_EXMP       = "";
MANPAGES_CCMD_TESTFINALE_NAME         = "testfinale <str> [lang]";
MANPAGES_CCMD_TESTFINALE_DESC         = "Launch a text interlude between episodes, with the {{str}} in the specified {{lang}} according to the localization table. The \"$\" symbol at the beginning of the string is implied automatically. {{Lang}} can consist of two or three characters, and if not specified, the current locale is used.\n\nTo output localized text to the console, you can use the {{printlocalized}} command.";
MANPAGES_CCMD_TESTFINALE_EXMP         = "testfinale c2text\tLaunch the text screen with the string {{$C2TEXT}} (end of Doom 2's second episode) in the current locale.\ntestfinale c2text es\tLaunch the text screen with the string {{$C2TEXT}} in Spanish.";
MANPAGES_CCMD_TOGGLEHUD_NAME          = "togglehud";
MANPAGES_CCMD_TOGGLEHUD_DESC          = "Temporarily disables the display of the HUD and weapon hands; often used for creating screenshots on maps. To return to the original view, on many engine versions, it is sufficient to open and close the main menu via {{Escape}}.";
MANPAGES_CCMD_TOGGLEHUD_EXMP          = "";
MANPAGES_CCMD_TOGGLEMESSAGES_NAME     = "togglemessages";
MANPAGES_CCMD_TOGGLEMESSAGES_DESC     = "Enables/disables the display of messages during play. This command does not affect the saving of messages in the console buffer.";
MANPAGES_CCMD_TOGGLEMESSAGES_EXMP     = "";
MANPAGES_CCMD_TYPE_NAME               = "type <file>";
MANPAGES_CCMD_TYPE_DESC               = "Output the contents of a loaded text {{file}} to the console.";
MANPAGES_CCMD_TYPE_EXMP               = "type credits/icebrk1a.txt\tOutput the contents of the file {{credits/icebrk1a.txt}} (located in *zdoom.pk3) - information about the source of the ice cracking sound used in ZDoom ports.";
MANPAGES_CCMD_TYPETABLE_NAME          = "typetable";
MANPAGES_CCMD_TYPETABLE_DESC          = "A debug command with long output that a user will never need. Output all cells of the hash table (as lists/chains) of all existing internal types, as well as statistics on the hash function efficiency.";
MANPAGES_CCMD_TYPETABLE_EXMP          = "";
MANPAGES_CCMD_UNDOCOLORPIC_NAME       = "undocolorpic";
MANPAGES_CCMD_UNDOCOLORPIC_DESC       = "A command intended exclusively for the \"ColorpickerMenu\" color selection menu; corresponds to the \"Undo changes\" button there. Not applicable when working through the console.";
MANPAGES_CCMD_UNDOCOLORPIC_EXMP       = "";
MANPAGES_CCMD_VID_LIST_SDL_RENDER_DRIVERS_NAME = "vid_list_sdl_render_drivers";
MANPAGES_CCMD_VID_LIST_SDL_RENDER_DRIVERS_DESC = "Output all available drivers for rendering via SDL.";
MANPAGES_CCMD_VID_LIST_SDL_RENDER_DRIVERS_EXMP = "";
MANPAGES_CCMD_VID_SCALETOHEIGHT_NAME  = "vid_scaletoheight <height>";
MANPAGES_CCMD_VID_SCALETOHEIGHT_DESC  = "Setting the emulated resolution {{height}} for fitting the game display window. Usually more convenient to use the \"Options\" -> \"Video Mode\" menu.";
MANPAGES_CCMD_VID_SCALETOHEIGHT_EXMP  = "vid_scaletoheight 1080\tSet the height to 1080 pixels (FullHD).";
MANPAGES_CCMD_VID_SCALETOLOWEST_NAME  = "vid_scaletolowest";
MANPAGES_CCMD_VID_SCALETOLOWEST_DESC  = "Fitting the window to the lowest possible resolution with the current screen characteristics. Usually more convenient to use the \"Options\" -> \"Video Mode\" menu.";
MANPAGES_CCMD_VID_SCALETOLOWEST_EXMP  = "";
MANPAGES_CCMD_VID_SCALETOWIDTH_NAME   = "vid_scaletowidth <width>";
MANPAGES_CCMD_VID_SCALETOWIDTH_DESC   = "Setting the emulated resolution {{width}} for fitting the game display window. Usually more convenient to use the \"Options\" -> \"Video Mode\" menu.";
MANPAGES_CCMD_VID_SCALETOWIDTH_EXMP   = "vid_scaletowidth 1920\tSet the width to 1920 pixels (FullHD).";
MANPAGES_CCMD_VID_SETSCALE_NAME       = "vid_setscale <x> <y> [linear] [pixel-shape]";
MANPAGES_CCMD_VID_SETSCALE_DESC       = "Setting the resolution of a new display window according to the specified parameters. Usually more convenient to use the \"Options\" -> \"Video Mode\" menu.";
MANPAGES_CCMD_VID_SETSCALE_EXMP       = "";
MANPAGES_CCMD_VID_SETSIZE_NAME        = "vid_setsize";
MANPAGES_CCMD_VID_SETSIZE_DESC        = "Setting the display window size. Usually more convenient to use the \"Options\" -> \"Video Mode\" menu.";
MANPAGES_CCMD_VID_SETSIZE_EXMP        = "";
MANPAGES_CCMD_VID_SHOWCURRENTSCALING_NAME = "vid_showcurrentscaling";
MANPAGES_CCMD_VID_SHOWCURRENTSCALING_DESC = "Show the current display window parameters (scaling, actual resolution of the current screen, and emulated screen resolution). Usually more convenient to use the \"Options\" -> \"Video Mode\" menu.";
MANPAGES_CCMD_VID_SHOWCURRENTSCALING_EXMP = "";
MANPAGES_CCMD_VK_LISTDEVICES_NAME     = "vk_listdevices";
MANPAGES_CCMD_VK_LISTDEVICES_DESC     = "Display all devices (GPUs) that Vulkan can work with.";
MANPAGES_CCMD_VK_LISTDEVICES_EXMP     = "";
MANPAGES_CCMD_VMENGINE_NAME           = "vmengine <default|checked|unchecked>";
MANPAGES_CCMD_VMENGINE_DESC           = "Can only be applied at engine startup. When compiling without JIT, set the \"VMExec\" virtual machine to the checked version ({{checked}}), unchecked ({{unchecked}}), or reset to default ({{default}} variant, determined by the presence of {{#define NDEBUG}} during build; in most builds this corresponds to the {{checked}} variant). Only applies to functions that have not been JIT-compiled.\n\nGiven that JIT compilation is now enabled by default in all engines, the usefulness of the command is questionable.";
MANPAGES_CCMD_VMENGINE_EXMP           = "";
MANPAGES_CCMD_WRITEINI_NAME           = "writeini [ini-file]";
MANPAGES_CCMD_WRITEINI_DESC           = "Write the current configuration to the configuration file. You can specify the {{ini-file}} argument, then the write will be performed to it; arbitrary paths in the file system are allowed.";
MANPAGES_CCMD_WRITEINI_EXMP           = "writeini test.ini\tWrite configuration to file {{test.ini}}.\nwriteini C:\\Temp\\test.ini\tWrite configuration to file at path {{C:\\Temp\\test.ini}} (if there are write permissions).";
MANPAGES_CCMD_WRITEMIDI_NAME          = "writemidi <midi> <out_file(!)> ";
MANPAGES_CCMD_WRITEMIDI_DESC          = "Save the MIDI track with the specified {{name}} to a file. It is permissible to use the \"*\" symbol in place of the name to record the currently playing track to disk.\n\nAttention! On almost all engine versions, due to a bug, the {{out_file}} argument is ignored, and the output file is always named the same as the MIDI track itself. Perhaps the best solution would be to use a resource editor.";
MANPAGES_CCMD_WRITEMIDI_EXMP          = "writemidi d_romero x.mid\tWrite the composition {{d_romero}} from Doom 2 to the file \"d_romero\" (or to the file \"{{x.mid}}\" if the bug has already been fixed in the current engine version).";
MANPAGES_CCMD_WRITEWAVE_NAME          = "writewave <midi> <filename> [subsong] [sample rate] [synth name] [soundfont]";
MANPAGES_CCMD_WRITEWAVE_DESC          = "Write the MIDI as a RIFF WAV file with the specified parameters. For the {{synth name}} parameter, the names \"WildMidi\", \"GUS\", \"Timidity\", \"FluidSynth\", \"OPL\", \"OPN\" or \"ADL\" can be used; \"FluidSynth\" is used by default. It is acceptable to use the \"*\" symbol instead of the {{midi}} name to write the currently playing track to disk. If \"0\" is specified for {{subsong}} and {{sample rate}}, the properties set by the track itself are used.\n\nAttention! The passed arguments are practically not checked for correctness; the game may crash. Perhaps the best solution would be to use a resource editor.";
MANPAGES_CCMD_WRITEWAVE_EXMP          = "";
