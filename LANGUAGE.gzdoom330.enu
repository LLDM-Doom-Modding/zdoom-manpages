MANPAGES_CCMD_MAN_NAME                = "man <COMMAND|help>";
MANPAGES_CCMD_MAN_DESC                = "Main manpages utility command. Prints a help for the specified {{COMMAND}} and its usage examples, if available. \"{{man help}}\" displays this help. Also, see commands {{man-search}} to search through all manpages and {{man-list}} for a list of all known pages.\n\nPlease note that if you are using an old engine version, some commands that are already in {{man}} database may not exist.";
MANPAGES_CCMD_MAN_EXMP                = "man summon\tPrints help for command {{summon}}.\nman +zoom\tPrints help for hold/unhold commands {{+zoom}}/{{-zoom}}.\nman console\tPrints help for the {{console usage}}.\nman help\tPrints this help.\nman --help\tSame as above for the convenience of main OS terminal and console users (also recognizes {{man -h}} and {{man /?}}).";
MANPAGES_CCMD_MANSEARCH_NAME          = "man-search <search pattern ...>";
MANPAGES_CCMD_MANSEARCH_DESC          = "Search for {{pattern}} across all the manpages. The {{pattern}} can consist of several words.";
MANPAGES_CCMD_MANSEARCH_EXMP          = "man-search sound\tSearch for the word \"sound\" (all commands related to sounds).\nman-search acs script\tFind all commands that mention ACS scripts.";
MANPAGES_CCMD_MANLIST_NAME            = "man-list";
MANPAGES_CCMD_MANLIST_DESC            = "Lists all known manpages.";
MANPAGES_CCMD_MANLIST_EXMP            = "";
MANPAGES_USAGE_CONSOLE_NAME           = "Help: console usage";
MANPAGES_USAGE_CONSOLE_DESC           = "By default the console toggles when pressing \"{{~}}\", and closes when pressing {{Escape}}.\n\nYou can access commands history with {{Up}}/{{Down}} arrows for previous/next history item. You can scroll the ZDoom console output (buffer) using {{the mouse wheel}} and the {{PgUp}}/{{PgDn}} keys. In the same way you can page through the output at once by holding the {{Ctrl}} key. The {{Ctrl + Home}}/{{Ctrl + End}} combinations jump directly to the start/end of the console buffer.";
MANPAGES_USAGE_CONSOLE_EXMP           = "{{(More precisely, related commands.)}}\nclear\tClear the console.\nman CCMD\tShow help for the specified {{console command}} (CCMD).\nlanguage en\tSwitch to English.\nlanguage es\tSwitch to Spanish, etc for other languages.";
