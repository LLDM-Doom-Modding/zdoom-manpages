MANPAGES_CCMD_MENU_MAPCOLORS_NAME     = "menu_mapcolors";
MANPAGES_CCMD_MENU_MAPCOLORS_DESC     = "Activates the {{custom automap colors}} menu.";
MANPAGES_CCMD_MENU_MAPCOLORS_EXMP     = "";
MANPAGES_CCMD_MENU_MESSAGES_NAME      = "menu_messages";
MANPAGES_CCMD_MENU_MESSAGES_DESC      = "Activates the {{message options}} menu.";
