MANPAGES_CCMD_MENU_KEYS_NAME          = "menu_keys";
MANPAGES_CCMD_MENU_KEYS_DESC          = "Activates the {{customize controls}} menu.";
MANPAGES_CCMD_MENU_KEYS_EXMP          = "";
MANPAGES_CCMD_MENU_LOAD_NAME          = "menu_load";
MANPAGES_CCMD_MENU_LOAD_DESC          = "Activates the {{load game menu}}.";
