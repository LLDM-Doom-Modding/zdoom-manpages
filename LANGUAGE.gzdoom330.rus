MANPAGES_CCMDHOLD_ZOOM_EXMP           = "";
MANPAGES_CCMD_ACSPROFILE_NAME         = "acsprofile [clear | [<сортировать-по>] [<лимит>]]";
MANPAGES_CCMD_ACSPROFILE_DESC         = "Предоставляет информацию профилирования {{ACS}}. Можно передать следующие необязательные аргументы:\n- {{сортировать-по}} указывает, по какой колонке сортировать (total, min, max, avg или runs). По умолчанию - total.\n- {{лимит}} задает предел, сколько строк выводить. По умолчанию - 10. 0 или меньше выведет все скрипты или функции, у которых был хотя бы один запуск.\n- {{clear}} сбрасывает всю статистику профилирования в 0. Не может использоваться совместно с другими двумя опциями.";
MANPAGES_CCMD_ACSPROFILE_EXMP         = "acsprofile\tСписок с сортировкой по полю \"Total\" (общее время исполнения), десять верхних позиций.\nacsprofile avg\tДесять верхних позиций по среднему времени исполнения.\nacsprofile total 0\tПолный список скриптов с сортировкой по общему времени исполнения.\nacsprofile max 7\tСемь верхних позиций по максимальному времени исполнения.\nacsprofile clear\tСбросить счетчики всех скриптов. Полезно сразу после загрузки карты для избавления от типов скриптов OPEN и ENTER.";
MANPAGES_CCMD_ACTORLIST_NAME          = "actorlist [класс или TID]";
MANPAGES_CCMD_ACTORLIST_DESC          = "Выводит список всех акторов на карте, по одному в строке вида \"ClassName at (X, Y, Z)\". В конце списка печатается общее количество найденных акторов. Если передать имя класса актора, список будет отфильтрован по этому классу. Если вместо имени класса передать {{TID}}, фильтрация будет выполнена по {{TID}}.";
MANPAGES_CCMD_ACTORLIST_EXMP          = "actorlist\tВывести список всех акторов, существующих на карте.\nactorlist clip\tВывести всех акторов {{Clip}} (магазин для пулемета из Doom и Doom 2) на карте.\nactorlist medikit\tВывести всех акторов {{Medikit}} (большая аптечка из Doom и Doom 2) на карте.\nactorlist 100\tВывести всех акторов с TID {{100}}.";
MANPAGES_CCMD_ACTORNUM_NAME           = "actornum [класс или TID]";
MANPAGES_CCMD_ACTORNUM_DESC           = "Выводит общее количество всех акторов на карте. Если передать имя класса, будет выведено количество только этого класса. Если вместо имени класса указать {{TID}}, будет выведено количество акторов с этим {{TID}}.";
MANPAGES_CCMD_ACTORNUM_EXMP           = "actornum megasphere\tПокажет, сколько мегасфер осталось на карте.\nactornum doomplayer\tПокажет текущее число игроков и кукол вуду (если используются на карте) в Doom.";
MANPAGES_CCMD_ADDBOT_NAME             = "addbot [имя]";
MANPAGES_CCMD_ADDBOT_DESC             = "Создает бота. Если указано {{имя}}, появится соответствующий бот из bots.cfg. В противном случае из bots.cfg бот будет выбран случайным образом.";
MANPAGES_CCMD_ADDBOT_EXMP             = "addbot\tДобавить случайного бота.\naddbot flare\tДобавить бота с именем {{Flare}}.";
MANPAGES_CCMD_ADDKEYSECTION_NAME      = "addkeysection <заголовок меню> <секция ini>";
MANPAGES_CCMD_ADDKEYSECTION_DESC      = "{{Команда предназначена в первую очередь для KEYCONF, не для консоли}}. Эта команда выполняет два действия. Во-первых, она добавляет новый заголовок в меню управления, используя параметр {{заголовок меню}}. Можно использовать команду {{addmenukey}} для добавления собственных клавиш под этим заголовком. Во-вторых, она загружает все привязки из соответствующей {{секции ini}} в ini-файле пользователя. Эту команду можно использовать несколько раз для создания различных разделов в меню и ini для разных наборов команд. Если использовать заголовок, который уже есть в меню, новые элементы управления, добавленные через {{addmenukey}}, появятся в конце этого раздела, но привязки из ini не будут загружены повторно.";
MANPAGES_CCMD_ADDKEYSECTION_EXMP      = "";
MANPAGES_CCMD_ADDMENUKEY_NAME         = "addmenukey <описание> <команда>";
MANPAGES_CCMD_ADDMENUKEY_DESC         = "{{Команда предназначена в первую очередь для KEYCONF, не для консоли}}. Добавляет новый элемент управления в меню настроек. {{описание}} - это название этого элемента в меню, а {{команда}} - консольная команда или псевдоним (alias), которые будут выполнены при активации этого элемента. Новые элементы добавляются в последний раздел, созданный с помощью addkeysection.";
MANPAGES_CCMD_ADDMENUKEY_EXMP         = "";
MANPAGES_CCMD_ADDPLAYERCLASS_NAME     = "addplayerclass <класс игрока> [nomenu]";
MANPAGES_CCMD_ADDPLAYERCLASS_DESC     = "{{Команда предназначена в первую очередь для KEYCONF, не для консоли}}. Добавляет указанный {{класс игрока}} в список {{доступных классов}}. Если добавлено ключевое слово {{nomenu}}, класс будет доступен только в {{настройках игрока}} (player setup) и не будет отображаться в {{меню выбора класса}} при старте игры.";
MANPAGES_CCMD_ADDPLAYERCLASS_EXMP     = "";
MANPAGES_CCMD_ADDSLOT_NAME            = "addslot <слот> <оружие>";
MANPAGES_CCMD_ADDSLOT_DESC            = "{{Команда предназначена в первую очередь для KEYCONF, не для консоли}}. Добавляет оружие в список указанного оружейного слота. Это позволяет игроку выбирать кастомное оружие из PWAD, используя обычные клавиши выбора оружия.";
MANPAGES_CCMD_ADDSLOT_EXMP            = "";
MANPAGES_CCMD_ADDSLOTDEFAULT_NAME     = "addslotdefault <слот> <оружие>";
MANPAGES_CCMD_ADDSLOTDEFAULT_DESC     = "{{Команда предназначена в первую очередь для KEYCONF, не для консоли}}. Добавляет оружие в список указанного оружейного слота, но только если это оружие еще не назначено ни в один другой слот. Если оружие уже присутствует в каком-либо слоте, команда ничего не сделает. При использовании внутри {{файла (lump) KEYCONF}} этой команде должна предшествовать команда {{weaponsection}}.";
MANPAGES_CCMD_ADDSLOTDEFAULT_EXMP     = "";
MANPAGES_CCMD_ALIAS_NAME              = "alias [имя] [строка_команды]";
MANPAGES_CCMD_ALIAS_DESC              = "Если вызвать без параметров, выведет список всех текущих псевдонимов (alias). Если указано только {{имя}}, псевдоним будет удален. Если указана и {{строка_команды}}, она будет сохранена под этим именем. Например, чтобы создать команду для уничтожения монстров:\nalias massacre \"kill monsters\"\n\nТеперь команда massacre будет убивать всех монстров. Можно использовать {{;}} для объединения команд:\nalias weirdness \"kill monsters; Give all; Summon doomimp\"\n\nЭто убьет монстров, выдаст инвентарь и призовет импа. Используйте {{wait (тики)}} для паузы между командами:\nalias \"kill monsters; Give all; wait 10; Summon doomimp\"\n\nЕсли псевдоним стал слишком длинным, можно сослаться на другой alias. Псевдонимы можно редактировать напрямую в {{zdoom.ini}}.\n\nДля создания псевдонима, срабатывающего на нажатие и отпускание клавиши, используйте {{+/-}} перед именем и привязывайте клавишу к версии с {{+}}.";
MANPAGES_CCMD_ALIAS_EXMP              = "";
MANPAGES_CCMD_AM_CLEARMARKS_NAME      = "am_clearmarks";
MANPAGES_CCMD_AM_CLEARMARKS_DESC      = "Удаляет все метки, поставленные пользователем на автокарте.";
MANPAGES_CCMD_AM_CLEARMARKS_EXMP      = "";
MANPAGES_CCMD_AM_GOBIG_NAME           = "am_gobig";
MANPAGES_CCMD_AM_GOBIG_DESC           = "Устанавливает масштаб автокарты так, чтобы был виден весь уровень целиком.";
MANPAGES_CCMD_AM_GOBIG_EXMP           = "";
MANPAGES_CCMD_AM_RESTORECOLORS_NAME   = "am_restorecolors";
MANPAGES_CCMD_AM_RESTORECOLORS_DESC   = "Сбрасывает пользовательские цвета автокарты к значениям по умолчанию.";
MANPAGES_CCMD_AM_RESTORECOLORS_EXMP   = "";
MANPAGES_CCMD_AM_SETMARK_NAME         = "am_setmark";
MANPAGES_CCMD_AM_SETMARK_DESC         = "Ставит метку в центре экрана (по стрелке игрока в режиме следования или по перекрестию в свободном режиме).";
MANPAGES_CCMD_AM_SETMARK_EXMP         = "";
MANPAGES_CCMD_AM_TOGGLEFOLLOW_NAME    = "am_togglefollow";
MANPAGES_CCMD_AM_TOGGLEFOLLOW_DESC    = "Переключает режим следования на автокарте.";
MANPAGES_CCMD_AM_TOGGLEFOLLOW_EXMP    = "";
MANPAGES_CCMD_AM_TOGGLEGRID_NAME      = "am_togglegrid";
MANPAGES_CCMD_AM_TOGGLEGRID_DESC      = "Включает или выключает отображение сетки на автокарте.";
MANPAGES_CCMD_AM_TOGGLEGRID_EXMP      = "";
MANPAGES_CCMD_AM_TOGGLETEXTURE_NAME   = "am_toggletexture";
MANPAGES_CCMD_AM_TOGGLETEXTURE_DESC   = "Включает или выключает текстурированную автокарту. Примечание: для работы текстур требуются построенные {{GL-ноды}}. Если они отсутствуют, карта останется нетекстурированной.";
MANPAGES_CCMD_AM_TOGGLETEXTURE_EXMP   = "";
MANPAGES_CCMD_AM_ZOOM_NAME            = "am_zoom <значение>";
MANPAGES_CCMD_AM_ZOOM_DESC            = "Приближает или отдаляет масштаб автокарты в зависимости от заданного значения.";
MANPAGES_CCMD_AM_ZOOM_EXMP            = "";
MANPAGES_CCMD_ANUBIS_NAME             = "anubis";
MANPAGES_CCMD_ANUBIS_DESC             = "Включает или выключает режимы страха у монстров. Испуганные монстры будут убегать от игрока и атаковать гораздо реже.";
MANPAGES_CCMD_ANUBIS_EXMP             = "";
MANPAGES_CCMD_ARCHIVECVAR_NAME        = "archivecvar <CVAR>";
MANPAGES_CCMD_ARCHIVECVAR_DESC        = "Когда вы создаете пользовательскую переменную (CVAR) через команду set, она обычно не сохраняется в {{ini}}. Команда archivecvar позволяет пометить переменную как архивную, чтобы ее значение сохранялось после выхода из игры. Не рекомендуется использовать это для неархивных системных переменных, так как это может привести к побочным эффектам в работе скриптов.";
MANPAGES_CCMD_ARCHIVECVAR_EXMP        = "";
MANPAGES_CCMD_ATEXIT_NAME             = "atexit [команда]";
MANPAGES_CCMD_ATEXIT_DESC             = "Если указать команду, она будет добавлена в список действий, выполняемых при выходе из игры. Команды выполняются в порядке, обратном их добавлению. Без аргументов atexit выведет список всех команд, назначенных на выполнение при выходе. Команды не сохраняются в конфигурационный файл.";
MANPAGES_CCMD_ATEXIT_EXMP             = "atexit \"echo Hello world!\"\tВывести при выходе надпись \"Hello world!\".";
MANPAGES_CCMD_BIND_NAME               = "bind [клавиша] [действие]";
MANPAGES_CCMD_BIND_DESC               = "Без параметров выводит список всех клавиш, к которым привязаны действия. Если указан один параметр ({{клавиша}}), отображает действие, связанное с ним. Если указаны оба аргумента, привязывает {{действие}} к {{клавише}}.";
MANPAGES_CCMD_BIND_EXMP               = "bind mouse3 linetarget\tПривязать к средней кнопке мыши (\"{{mouse3}}\") команду {{linetarget}}.\nbind ; \"give infrared\"\tПривязать к клавише точки с запятой команду {{give infrared}}.";
MANPAGES_CCMD_BINDDEFAULTS_NAME       = "binddefaults";
MANPAGES_CCMD_BINDDEFAULTS_DESC       = "Привязывает все клавиши к их командам по умолчанию. Не отвязывает клавиши без стандартных привязок, поэтому для полного восстановления настроек сначала используйте unbindall.";
MANPAGES_CCMD_BINDDEFAULTS_EXMP       = "";
MANPAGES_CCMD_BUDDHA_NAME             = "buddha";
MANPAGES_CCMD_BUDDHA_DESC             = "Дает вам неуязвимое очко здоровья: ни одна обычная атака не сможет отнять его (некоторые смертельные эффекты, например телефраг, все равно убьют). Этот чит удобнее god mode для тестирования монстров или уровней.";
MANPAGES_CCMD_BUDDHA_EXMP             = "";
MANPAGES_CCMD_BUDDHA2_NAME            = "buddha2";
MANPAGES_CCMD_BUDDHA2_DESC            = "Похоже на {{buddha}}, но последнее очко здоровья не может снять ничто, включая телефраг.";
MANPAGES_CCMD_BUDDHA2_EXMP            = "";
MANPAGES_CCMD_BUMPGAMMA_NAME          = "bumpgamma";
MANPAGES_CCMD_BUMPGAMMA_DESC          = "Увеличивает текущий уровень гаммы на 0.1. Если новое значение превышает 3.0, счетчик сбрасывается в 1.0.";
MANPAGES_CCMD_BUMPGAMMA_EXMP          = "";
MANPAGES_CCMD_CENTERVIEW_NAME         = "centerview";
MANPAGES_CCMD_CENTERVIEW_DESC         = "Сбрасывает {{свободный обзор}} в горизонтальное положение.";
MANPAGES_CCMD_CENTERVIEW_EXMP         = "";
MANPAGES_CCMD_CHANGEMAP_NAME          = "changemap <имя_lump>";
MANPAGES_CCMD_CHANGEMAP_DESC          = "Показывает межмиссионный экран и перемещает игрока на указанную карту (например, \"changemap e2m3\" или \"changemap map27\"), сохраняя инвентарь и здоровье. Вместо имени карты можно использовать:\n- *: переход на текущую карту.\n- +: переход на следующую карту из {{MAPINFO}}.\n- +$: переход на следующую секретную карту из MAPINFO.";
MANPAGES_CCMD_CHANGEMAP_EXMP          = "changemap map04\tПерейти на карту MAP04 с сохранением прогресса.\nchangemap +\tПерейти на карту далее. Как команда {{nextmap}}, но с сохранением прогресса.";
MANPAGES_CCMD_CHANGEMUS_NAME          = "changemus [<музыка> [<трек>]]";
MANPAGES_CCMD_CHANGEMUS_DESC          = "Меняет текущую музыку. {{Музыка}} - это имя lump, файл на диске (не обязательно указанный через \"-file\") или веб-адрес. Если lump содержит несколько треков (MIDI типа 2, некоторые XMI и др.), можно указать номер трека через второй параметр.\n\nБез параметров команда выводит в {{консоль}} имя текущего lump или файла.";
MANPAGES_CCMD_CHANGEMUS_EXMP          = "changemus\tПоказать текущую воспроизводимую композицию.\nchangemus d_romero\tУстановить трек {{D_ROMERO}}.";
MANPAGES_CCMD_CHANGESKY_NAME          = "changesky <новая_текстура>";
MANPAGES_CCMD_CHANGESKY_DESC          = "Заменяет текстуру неба на указанную. В {{MAPINFO}}, в разделе \"Map definition\", исходная текстура объявляется через \"{{sky1}}\".";
MANPAGES_CCMD_CHANGESKY_EXMP          = "changesky rsky1\tВ Doom 2 (или WAD на его основе) меняет небо на 'RSKY1' из lump TEXTURE1.\nchangesky flat5_7\tИзменяет скайбокс на текстуру 'FLAT5_7' (в Doom это текстура булыжников для пола/потолка).";
MANPAGES_CCMD_CHASE_NAME              = "chase";
MANPAGES_CCMD_CHASE_DESC              = "Включает/выключает {{режим камеры от третьего лица}}. Считается читом.";
MANPAGES_CCMD_CHASE_EXMP              = "";
MANPAGES_CCMD_CLEAN_NAME              = "clean";
MANPAGES_CCMD_CLEAN_DESC              = "Выводит подстраивающие коэффициенты отображения (clean factors) для масштабирования {{меню}}, доступные при текущем разрешении.";
MANPAGES_CCMD_CLEAN_EXMP              = "";
MANPAGES_CCMD_CLEARALIASES_NAME       = "clearaliases";
MANPAGES_CCMD_CLEARALIASES_DESC       = "Удаляет все существующие псевдонимы консоли.";
MANPAGES_CCMD_CLEARALIASES_EXMP       = "";
MANPAGES_CCMD_CLEARPLAYERCLASSES_NAME = "clearplayerclasses";
MANPAGES_CCMD_CLEARPLAYERCLASSES_DESC = "Удаляет все {{классы игрока}} из списка {{доступных классов}} при начале {{новой игры}} или изменении {{настройки игрока}}. Всегда за этой командой должны следовать вызовы {{addplayerclass}}.";
MANPAGES_CCMD_CLEARPLAYERCLASSES_EXMP = "";
MANPAGES_CCMD_CLEARWALLCYCLES_NAME    = "clearwallcycles";
MANPAGES_CCMD_CLEARWALLCYCLES_DESC    = "Сбрасывает счетчик минимальных циклов отрисовки стен. Используется для профилирования.";
MANPAGES_CCMD_CLEARWALLCYCLES_EXMP    = "";
MANPAGES_CCMD_CLOSEMENU_NAME          = "closemenu";
MANPAGES_CCMD_CLOSEMENU_DESC          = "Закрывает текущее {{меню}}. Особенно полезно в {{пользовательских меню}} для возврата в игру.";
MANPAGES_CCMD_CLOSEMENU_EXMP          = "";
MANPAGES_CCMD_CMDLIST_NAME            = "cmdlist [шаблон]";
MANPAGES_CCMD_CMDLIST_DESC            = "Выводит список всех консольных команд ZDoom. При указании {{шаблона}} покажет только подходящие команды. В шаблоне можно использовать * (ноль или больше символов) и ? (ровно один символ).";
MANPAGES_CCMD_CMDLIST_EXMP            = "cmdlist\tВывести все доступные команды. Именно так генерировался первоначальный список команд для проекта manpages.\ncmdlist *cvar*\tВывести все команды, в которых встречается слово \"{{cvar}}\".";
MANPAGES_CCMD_COUNTDECALS_NAME        = "countdecals";
MANPAGES_CCMD_COUNTDECALS_DESC        = "Возвращает внутренний счетчик автоматически созданных деккалов.";
MANPAGES_CCMD_COUNTDECALS_EXMP        = "";
MANPAGES_CCMD_COUNTITEMS_NAME         = "countitems [класс или TID]";
MANPAGES_CCMD_COUNTITEMS_DESC         = "Выводит список всех счетных {{предметов}} на карте в формате ClassName at (X, Y, Z). При указании класса фильтрует список. В конце выводится общее количество. Если вместо класса указан {{TID}}, фильтрация идет по нему.";
MANPAGES_CCMD_COUNTITEMS_EXMP         = "countitems\tВывести список всех оставшихся на уровне предметов, которые учитываются при подсчете процента.\ncountitems healthbonus\tВывести список только предметов {{HealthBouns}}. Обычно в этом случае удобнее использовать команду {{items}}.";
MANPAGES_CCMD_COUNTITEMSNUM_NAME      = "countitemsnum [класс или TID]";
MANPAGES_CCMD_COUNTITEMSNUM_DESC      = "Выводит общее количество счетных предметов на карте. При указании класса - только для него. При указании {{TID}} - только с этим идентификатором.";
MANPAGES_CCMD_COUNTITEMSNUM_EXMP      = "countitemsnum\tВывести общее число всех оставшихся на уровне предметов, которые учитываются при подсчете процента.\ncountitemsnum healthbonus\tВывести общее число только предметов {{HealthBouns}}. Обычно в этом случае удобнее использовать команду {{itemsnum}}.";
MANPAGES_CCMD_CRASHOUT_NAME           = "crashout";
MANPAGES_CCMD_CRASHOUT_DESC           = "Тестовый отладочный инструмент. Намеренно вызывает сбой через {{попытку записи}} по {{адресу 0}}.";
MANPAGES_CCMD_CRASHOUT_EXMP           = "";
MANPAGES_CCMD_CROUCH_NAME             = "crouch";
MANPAGES_CCMD_CROUCH_DESC             = "Включает/выключает режим {{приседания}}. Не путать с {{+crouch}}, который работает только при удержании клавиши.";
MANPAGES_CCMD_CROUCH_EXMP             = "";
MANPAGES_CCMD_CURRENTPOS_NAME         = "currentpos";
MANPAGES_CCMD_CURRENTPOS_DESC         = "Выводит позицию игрока: координаты X, Y, Z, угол, высоту пола, номер сектора и уровень освещения.";
MANPAGES_CCMD_CURRENTPOS_EXMP         = "";
MANPAGES_CCMD_CVARLIST_NAME           = "cvarlist [шаблон]";
MANPAGES_CCMD_CVARLIST_DESC           = "Выводит значения всех CVAR. Каждый может помечаться флагами:\nA: Archive - сохраняется в конфигурационном файле.\nU: User - переменная пользователя.\nS: Server - переменная сервера.\n-: Несвязываемая - меняется только через командную строку.\nL: Latched - изменения вступят в силу при перезагрузке.\nC: Callback - имеет внутренний обработчик.\n*: Custom - создана пользователем.\n\nПри указании {{шаблона}} выводятся только подходящие CVAR. Поддерживаются * и ?.";
MANPAGES_CCMD_CVARLIST_EXMP           = "";
MANPAGES_CCMD_CVARLISTPLAIN_NAME      = "cvarlistplain";
MANPAGES_CCMD_CVARLISTPLAIN_DESC      = "Аналог {{cvarlist}}, но без флагов и пользовательских CVAR. Используется для проверки полноты документации.";
MANPAGES_CCMD_CVARLISTPLAIN_EXMP      = "";
MANPAGES_CCMD_DEFAULTBIND_NAME        = "defaultbind <клавиша> <команда>";
MANPAGES_CCMD_DEFAULTBIND_DESC        = "Привязывает {{команду}} к клавише, только если клавиша не привязана и команда не привязана к другим клавишам. Полезно в {{KEYCONF}} для создания привязок по умолчанию без перезаписи настроек пользователя.";
MANPAGES_CCMD_DEFAULTBIND_EXMP        = "";
MANPAGES_CCMD_DIR_NAME                = "dir [<путь>/][шаблон]";
MANPAGES_CCMD_DIR_DESC                = "Выводит содержимое каталога с поддержкой масок. Без {{пути}} показывает каталог запуска игры.";
MANPAGES_CCMD_DIR_EXMP                = "dir\tПоказать все файлы в текущем каталоге.\ndir ./*.wad\tВывести все WAD-файлы в текущем каталоге. В случае регистрозависимой файловой системы может потребоваться написать \"{{dir ./*.WAD}}\".\ndir /usr/bin/ls*\tПоказать все файлы, начинающиеся на \"ls\", в каталоге \"/usr/bin\" (на ОС Linux и других POSIX-совместимых ОС).\ndir C:/Temp\tПоказать содержимое директории временных файлов \"C:\\Temp\" (на ОС Windows).";
MANPAGES_CCMD_DOUBLEBIND_NAME         = "doublebind [<клавиша>] [<команда>]";
MANPAGES_CCMD_DOUBLEBIND_DESC         = "Аналог {{bind}}, но для двойного нажатия. Если привязки нет, двойное нажатие работает как два обычных. Иначе первое нажатие выполняет bind, второе - doublebind.";
MANPAGES_CCMD_DOUBLEBIND_EXMP         = "doublebind 0 \"stat statistics\"\tПривязать к двойному нажатию на клавишу цифры \"{{0}}\" переключение команды {{stat statistics}} (статистика по пройденным уровням, отображается в левом нижнем углу).";
MANPAGES_CCMD_DROP_NAME               = "drop <предмет> [<количество>]";
MANPAGES_CCMD_DROP_DESC               = "Выбрасывает указанный предмет, если он есть в инвентаре. Предметы с флагами {{INVENTORY.UNDROPPABLE}} или {{INVENTORY.UNTOSSABLE}} выбросить нельзя. {{Количество}} задает число экземпляров. Нельзя выбросить больше, чем есть.";
MANPAGES_CCMD_DROP_EXMP               = "drop shotgun\tВыбросить дробовик.\ndrop clip 16\tВыбросить 16 патронов для пистолета и пулемета.";
MANPAGES_CCMD_DUMPACTORS_NAME         = "dumpactors";
MANPAGES_CCMD_DUMPACTORS_DESC         = "Выводит список всех классов объектов с их {{номером редактора}}, {{SpawnID}}, {{фильтром игры}}, модом и файлом (lump) в этом моде. Полезно для разрешения конфликтов в больших проектах. Из-за объема данных (в ZDoom >1300 акторов) используйте с logfile. Обработка может занять несколько секунд.";
MANPAGES_CCMD_DUMPACTORS_EXMP         = "";
MANPAGES_CCMD_DUMPCLASSES_NAME        = "dumpclasses [<базовый класс>]";
MANPAGES_CCMD_DUMPCLASSES_DESC        = "Выводит все классы в игре. С помощью {{базового класса}} можно отфильтровать список. Например, {{dumpclasses actor}} покажет только спавнимые классы. Для списка оружия используйте {{dumpclasses weapon}}. Список может быть длинным - лучше использовать logfile.";
MANPAGES_CCMD_DUMPCLASSES_EXMP        = "";
MANPAGES_CCMD_DUMPCONVERSATIONIDS_NAME = "dumpconversationids";
MANPAGES_CCMD_DUMPCONVERSATIONIDS_DESC = "Выводит все {{номера диалогов}} для акторов в текущей игре.";
MANPAGES_CCMD_DUMPCONVERSATIONIDS_EXMP = "";
MANPAGES_CCMD_DUMPGEOMETRY_NAME       = "dumpgeometry";
MANPAGES_CCMD_DUMPGEOMETRY_DESC       = "Выводит в logfile полный разбор геометрии карты: сектора, подсектора, сеги и вершины.";
MANPAGES_CCMD_DUMPGEOMETRY_EXMP       = "";
MANPAGES_CCMD_DUMPMAPTHINGS_NAME      = "dumpmapthings";
MANPAGES_CCMD_DUMPMAPTHINGS_DESC      = "Выводит все номера редактора карт для акторов в текущей игре.";
MANPAGES_CCMD_DUMPMAPTHINGS_EXMP      = "";
MANPAGES_CCMD_DUMPPORTALS_NAME        = "dumpportals";
MANPAGES_CCMD_DUMPPORTALS_DESC        = "Выводит в logfile отчет о всех {{порталах}} на карте с указанием покрываемых подсекторов.";
MANPAGES_CCMD_DUMPPORTALS_EXMP        = "";
MANPAGES_CCMD_DUMPSPAWNABLES_NAME     = "dumpspawnables";
MANPAGES_CCMD_DUMPSPAWNABLES_DESC     = "Выводит все {{номера спавна}} для акторов в текущей игре.";
MANPAGES_CCMD_DUMPSPAWNABLES_EXMP     = "";
MANPAGES_CCMD_DUMPSTATES_NAME         = "dumpstates";
MANPAGES_CCMD_DUMPSTATES_DESC         = "Выводит отладочную информацию о стейтах всех акторов. Вряд ли полезно обычным пользователям.";
MANPAGES_CCMD_DUMPSTATES_EXMP         = "";
MANPAGES_CCMD_ECHO_NAME               = "echo <строка>";
MANPAGES_CCMD_ECHO_DESC               = "Выводит {{строку}} в консоль. Поддерживает escape-последовательности.";
MANPAGES_CCMD_ECHO_EXMP               = "echo Hello!\tВывести строку \"Hello!\".\n\c[fire]Header: \c[darkgray]Some message\tВывести \"Header\" огненно-желтым цветом, а \"Some message\" серым.\necho \\n=======================\\n\\n\tВывести хорошо видимый разделитель.";
MANPAGES_CCMD_ENDGAME_NAME            = "endgame";
MANPAGES_CCMD_ENDGAME_DESC            = "Завершает текущую игру и возвращает на титульный экран.";
