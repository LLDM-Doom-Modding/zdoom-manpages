MANPAGES_CCMD_ANGLECONVTEST_NAME      = "angleconvtest";
MANPAGES_CCMD_ANGLECONVTEST_DESC      = "Внутренняя проверка конвертации углов в разные типы данных.\n- Оригинальный угол: (double) ang;\n- Получение DAngle::fromDeg(ang).BAMs();\n- Приведение к unsigned через (unsigned)(ang * (0x40000000 / 90.));\n- Приведение к signed через (unsigned)(int)(ang * (0x40000000 / 90.)).";
