MANPAGES_CCMD_CHANGESKILL_NAME        = "changeskill <уровень>";
MANPAGES_CCMD_CHANGESKILL_DESC        = "Изменяет {{уровень сложности}}, и, в отличие от переменной \"{{skill}}\", применяет его уже со следующего уровня, а не с новой игры. Нумерация начинается с нуля, и \"0\" обычно соответствует самому простому уровню сложности. В оригинальном Doom уровень \"4\" соответствует сложности \"Nightmare!\".";
MANPAGES_CCMD_CHANGESKILL_EXMP        = "Для Doom и Doom 2:\nchangeskill 0\t\"I'm too young to die.\"\nchangeskill 1\t\"Hey, not too rough.\"\nchangeskill 2\t\"Hurt me plenty.\"\nchangeskill 3\t\"Ultra-Violence.\"\nchangeskill 4\t\"Nightmare!\" ";
