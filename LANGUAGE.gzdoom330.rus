MANPAGES_CCMD_LISTBOTS_EXMP           = "";
MANPAGES_CCMD_LISTLIGHTS_NAME         = "listlights";
MANPAGES_CCMD_LISTLIGHTS_DESC         = "Выводит список всех {{динамических источников света}} (как прикрепленных, так и отдельных), а также их положение, цвет, радиус и количество стен и субсекторов, на которые они влияют.";
