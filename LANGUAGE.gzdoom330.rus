MANPAGES_CCMD_BENCH_NAME              = "bench";
MANPAGES_CCMD_BENCH_DESC              = "Запустить бенчмарк (анализ скорости работы) hardware-рендеринга на пять секунд. По завершению в директории запуска игры появится (или обновится) файл \"benchmarks.txt\" со срезом информации, полученной за эти пять секунд.";
