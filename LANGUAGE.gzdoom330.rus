MANPAGES_CCMD_MAN_NAME                = "man <КОМАНДА|help>";
MANPAGES_CCMD_MAN_DESC                = "Основная команда manpages. Выводит справку по указанной {{КОМАНДЕ}}, а также, если есть, примеры использования. \"{{man help}}\" выведет эту инструкцию. Также см. команды {{man-search}} для поиска по всем man-страницам и {{man-list}} для списка известных команд.\n\nЕсли используется старая версия игрового движка, некоторые команды, которые уже есть в базе данных {{man}}, могут отсутствовать.";
MANPAGES_CCMD_MAN_EXMP                = "man summon\tВыводит справку для команды {{summon}}.\nman +zoom\tВыводит справку для команд {{+zoom}}/{{-zoom}}, реагирующих на удержание/отжатие клавиши.\nman console\tВыводит справку {{по использованию консоли}}.\nman help\tВыводит эту справку.\nman --help\tТо же самое для удобства пользователей терминалов и консолей основных ОС (также поддерживаются {{man -h}} и {{man /?}}).";
MANPAGES_CCMD_MANSEARCH_NAME          = "man-search <шаблон поиска ...>";
MANPAGES_CCMD_MANSEARCH_DESC          = "Ищет {{шаблон}} по всем командам manpages. {{Шаблон}} может состоять из нескольких слов. {{Из-за ограничений консоли ZDoom поиск может осуществляться только на английском языке (без Unicode)}}!";
MANPAGES_CCMD_MANSEARCH_EXMP          = "man-search sound\tПоиск по слову \"sound\" (все команды, связанные со звуками).\nman-search acs script\tНайти все команды, в которых упоминаются ACS-скрипты.";
MANPAGES_CCMD_MANLIST_NAME            = "man-list";
MANPAGES_CCMD_MANLIST_DESC            = "Выводит список всех известных man-страниц.";
MANPAGES_CCMD_MANLIST_EXMP            = "";
MANPAGES_USAGE_CONSOLE_NAME           = "Справка: работа с консолью";
MANPAGES_USAGE_CONSOLE_DESC           = "По умолчанию консоль переключается по нажатию на \"{{~}}\", она же \"{{е}}\", и закрывается по нажатию на {{Escape}}.\n\nДоступ к истории команд осуществляется через стрелки: {{Вверх}} для предыдущей записи и {{Вниз}} для следующей. Прокручивать вывод (буфер) консоли ZDoom можно с помощью {{колеса мыши}} и кнопок {{PgUp}}/{{PgDn}}. Тем же образом можно листать сразу постранично, если зажать клавишу {{Ctrl}}. Сочетания {{Ctrl + Home}}/{{Ctrl + End}} переведут сразу в начало/конец буфера консоли.";
MANPAGES_USAGE_CONSOLE_EXMP           = "{{(Точнее, связанные команды.)}}\nclear\tОчистить консоль.\nman CCMD\tПоказать справку по указанной {{команде консоли}} (CCMD).\nlanguage ru\tПереключиться на русский язык.\nlanguage en\tПереключиться на английский, и так далее для других языков.";
