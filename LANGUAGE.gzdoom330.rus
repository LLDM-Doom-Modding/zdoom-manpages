MANPAGES_CCMD_GET_NAME                = "get <CVAR>";
MANPAGES_CCMD_GET_DESC                = "Отображает значение {{CVAR}}. Обычно это избыточно, так как ввод имени {{CVAR}} в консоли сам по себе приведет к тому же результату.";
MANPAGES_CCMD_GET_EXMP                = "";
MANPAGES_CCMD_GIVE_NAME               = "give <предмет>";
MANPAGES_CCMD_GIVE_DESC               = "Выдает {{предмет}} игроку. Команда понимает следующие специальные значения:\n- {{all}} - дает все;\n- {{everything}} - дает все, включая оружие с флагом {{WEAPON.CHEATNOTWEAPON}};\n- {{backpack}} - дает рюкзак в Doom, сумку (bag of holding) в Heretic и Hexen, или подсумок (ammo satchel) в Strife;\n- {{health}} - восстанавливает здоровье до максимума;\n- {{weapons}} - дает все оружие;\n- {{ammo}} - дает полный боезапас;\n- {{armor}} - дает полную броню;\n- {{keys}} - дает все ключи, которые привязаны к замкам.\n\nКоманда также принимает имена конкретных предметов. Используйте {{dumpclasses inventory}} для получения полного списка предметов.";
MANPAGES_CCMD_GIVE_EXMP               = "";
MANPAGES_CCMD_GL_PORTALINFO_NAME      = "gl_portalinfo";
MANPAGES_CCMD_GL_PORTALINFO_DESC      = "Запускает логирование информации о {{порталах}}.";
MANPAGES_CCMD_GL_PORTALINFO_EXMP      = "";
MANPAGES_CCMD_GOD_NAME                = "god";
MANPAGES_CCMD_GOD_DESC                = "Переключает режим бога (iddqd). Пока он активен, вам нельзя нанести урон обычными атаками (хотя некоторые вещи, такие как телефраг, все равно могут убить).";
MANPAGES_CCMD_GOD_EXMP                = "";
MANPAGES_CCMD_GOD2_NAME               = "god2";
MANPAGES_CCMD_GOD2_DESC               = "Аналогично команде {{god}}, за исключением того, что игрок получает абсолютную неуязвимость; ничто не может нанести ему урон, включая телефраг.";
MANPAGES_CCMD_GOD2_EXMP               = "";
MANPAGES_CCMD_HIDDENCOMPATFLAGS_NAME  = "hiddencompatflags";
MANPAGES_CCMD_HIDDENCOMPATFLAGS_DESC  = "Выводит шестнадцатеричные значения трех полей флагов совместимости. Позволяет проверить, применяют ли настройки {{MAPINFO}} или {{автоматическая совместимость}} определенные {{опции совместимости}}.";
MANPAGES_CCMD_HIDDENCOMPATFLAGS_EXMP  = "";
MANPAGES_CCMD_HISTORY_NAME            = "history";
MANPAGES_CCMD_HISTORY_DESC            = "Выводит недавно выполненные {{консольные команды}}, которые можно пролистывать клавишами стрелок вверх и вниз. В истории консоли может храниться до пятидесяти команд.";
MANPAGES_CCMD_HISTORY_EXMP            = "";
MANPAGES_CCMD_HXVISIT_NAME            = "hxvisit <номер_карты>";
MANPAGES_CCMD_HXVISIT_DESC            = "Переход на уровень, указанный в {{warptrans}}. В отличие от {{idclev}}, hxvisit определяет целевую карту, находя в {{MAPINFO}} запись с соответствующим значением {{warptrans}}. Таким образом, команда эмулирует {{чит-код}} visit из игры {{Hexen}}.";
MANPAGES_CCMD_HXVISIT_EXMP            = "";
MANPAGES_CCMD_IDCLEV_NAME             = "idclev <номер_слота>";
MANPAGES_CCMD_IDCLEV_DESC             = "Переход на уровень, указанный в {{номер_слота}}. Эмулирует чит-код {{idclev}}.";
