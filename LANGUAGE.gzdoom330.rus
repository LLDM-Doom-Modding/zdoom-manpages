MANPAGES_CCMD_WARP_NAME               = "warp <x-коорд> <y-коорд> [z-коорд]";
MANPAGES_CCMD_WARP_DESC               = "Мгновенно перемещает игрока по указанным координатам. Может использоваться вместе с {{idmypos}} для отладки проблем в конкретных областях карты.";
