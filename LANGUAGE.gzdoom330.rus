MANPAGES_CCMD_PRINTLOCALIZED_NAME     = "printlocalized <строка> [язык]";
MANPAGES_CCMD_PRINTLOCALIZED_DESC     = "Вывести {{строку}} на указанном {{языке}} согласно таблице локализации. Символ \"$\" в начале слова подразумевается автоматически. {{Язык}} может состоять из двух или трех символов, а если он не указан, используется текущая локаль.";
MANPAGES_CCMD_PRINTLOCALIZED_EXMP     = "printlocalized c2text\tВывести {{$C2TEXT}} (экран с текстом по окончанию второго эпизода Doom 2) на текущей локали.\nprintlocalized c2text es\tВывести {{$C2TEXT}} на испанском языке.\nprintlocalized gotarmor eng\tВывести {{$GOTARMOR}} на британском диалекте английского.";
MANPAGES_CCMD_PRINTSECTIONS_NAME      = "printsections"; // Same as for `dumplinktable`. It should work, but it won't. First appear in GZDoom.
MANPAGES_CCMD_PRINTSECTIONS_DESC      = "Выводит список секций и сегментов для уровня.";
MANPAGES_CCMD_PRINTSECTIONS_EXMP      = "";
MANPAGES_CCMD_PROFILETHINKERS_NAME    = "profilethinkers <сортировка> [limit]";
MANPAGES_CCMD_PROFILETHINKERS_DESC    = "Профилирование объектов класса Thinker - сбор информации о скорости обработки объектов мира - используется для определения наиболее медленных мест в коде. Профилирование запускается для всех объектов мира на следующий игровой такт (т. е. надо закрыть консоль). В результате выводится список в порядке {{сортировки}}, количеством не более чем {{лимит}} строк, если лимит указан. {{Сортировка}} может проводиться восемью способами:\n {{class}}, {{+c}} или {{1}} - по названию класса, прямой порядок, вверху \"A\".\n{{-class}}, {{-c}} или {{2}} - по названию класса, обратный порядок, вверху \"Z\".\n {{#}}, {{+#}} или {{3}}     - по числу объектов, прямой порядок, вверху минимум.\n{{-#}} или {{4}}         - по числу объектов, обратный порядок.\n {{avg}}, {{+a}} или {{5}}   - по среднему времени, прямой порядок, вверху минимум.\n{{-avg}}, {{-a}} или {{6}}   - по среднему времени, обратный порядок.\n {{total}}, {{+t}} или {{7}} - по общему времени, прямой порядок, вверху минимум. Этот вариант используется чаще всего.\n{{-total}}, {{-t}} или {{8}} - по общему времени, обратный порядок.\n\nВсе время указывается в миллисекундах. Среднее время равно общему времени, деленному на число объектов.";
MANPAGES_CCMD_PROFILETHINKERS_EXMP    = "profilethinkers 7\tЗапустить профилирование с сортировкой по общему времени. Позволяет быстро прикинуть, проблема в сложном коде или в большом числе объектов.\nprofilethinkers -# 15\tПосле профилирования оставить только 15 строк наиболее часто встречающихся объектов.\nprofilethinkers avg\tПрофилирование с сортировкой по среднему времени на один объект.";
