MANPAGES_CCMD_SND_LISTMIDIDEVICES_NAME = "snd_listmididevices";
MANPAGES_CCMD_SND_LISTMIDIDEVICES_DESC = "Эта команда выводит список доступных в системе {{MIDI-устройств}}. Устройства из этого списка можно использовать в переменной {{snd_mididevice}} для выбора устройства воспроизведения музыки. Устройства с отрицательными номерами предоставляются самим {{ZDoom}}.";
