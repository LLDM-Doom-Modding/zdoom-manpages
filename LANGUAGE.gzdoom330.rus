MANPAGES_CCMD_SPYPREV_EXMP            = "";
MANPAGES_CCMD_STAT_NAME               = "stat [страница]";
MANPAGES_CCMD_STAT_DESC               = "Отображает информацию о профилировании. Без параметров выводит список доступных экранов. Используйте один из них в качестве параметра {{страница}}, чтобы включить или выключить отображение соответствующего экрана.";
MANPAGES_CCMD_STAT_EXMP               = "";
MANPAGES_CCMD_STOP_NAME               = "stop";
MANPAGES_CCMD_STOP_DESC               = "Останавливает запись демо и закрывает игру.";
MANPAGES_CCMD_STOP_EXMP               = "";
MANPAGES_CCMD_STOPMUS_NAME            = "stopmus";
MANPAGES_CCMD_STOPMUS_DESC            = "Останавливает воспроизведение текущей музыки.";
MANPAGES_CCMD_STOPMUS_EXMP            = "";
MANPAGES_CCMD_SUMMON_NAME             = "summon <класс> [угол [TID [спец_действие [аргументы... ]]]]";
MANPAGES_CCMD_SUMMON_DESC             = "Создает нового актора перед игроком. Полный список акторов можно получить с помощью команды {{dumpclasses actor}}; для списка акторов, доступных в редакторе, используйте {{dumpmapthings}}. При призыве акторов из других игр они могут оказаться невидимыми, так как у игрового движка не найдется спрайтов для их отрисовки.\n\nПо умолчанию актор появляется лицом на восток, но, если указан параметр {{угол}}, актор появится под углом относительно направления взгляда игрока (0 - спиной к игроку, 180 - лицом к нему). Дополнительные параметры позволяют задать призываемому актору {{TID}}, {{action special}} (специальное действие) и аргументы этого действия.";
MANPAGES_CCMD_SUMMON_EXMP             = "summon shotgun\tСоздать актор {{Shotgun}}.\nsummon hellknight\tСоздать актора {{HellKnight}}.\nsummon hellknight 0\tСоздать актора {{HellKnight}}, отвернутого от игрока.\nsummon pistol 0 0 120 7 35 0 8 0\tСоздать предмет {{Pistol}}, после поднятия которого начинается небольшое землетрясение. Action special {{120}} означает вызов {{Radius_Quake}}, с последующими аргументами получается {{Radius_Quake( 7, 35, 0, 8, 0 );}}. Параметры {{угол}} и {{TID}} здесь не особо важны, поэтому поставлены в \"0\".";
MANPAGES_CCMD_SUMMONFOE_NAME          = "summonfoe <класс> [угол [TID [спец_действие [аргументы... ]]]]";
MANPAGES_CCMD_SUMMONFOE_DESC          = "То же, что и {{summon}}, но заставляет созданных монстров быть враждебными к игроку, независимо от наличия у актора флага {{FRIENDLY}}.";
MANPAGES_CCMD_SUMMONFOE_EXMP          = "";
MANPAGES_CCMD_SUMMONFRIEND_NAME       = "summonfriend <класс> [угол [TID [спец_действие [аргументы... ]]]]";
MANPAGES_CCMD_SUMMONFRIEND_DESC       = "То же, что и {{summon}}, но заставляет созданных монстров атаковать враждебных существ вместо игрока.";
MANPAGES_CCMD_SUMMONFRIEND_EXMP       = "";
MANPAGES_CCMD_SUMMONMBF_NAME          = "summonmbf <класс> [угол]";
MANPAGES_CCMD_SUMMONMBF_DESC          = "То же, что и {{summonfriend}}, но также дает актору флаг {{NOBLOCKMONST}}, позволяя ему пересекать линии, блокирующие монстров, как это делают дружественные существа в MBF.";
MANPAGES_CCMD_SUMMONMBF_EXMP          = "";
MANPAGES_CCMD_TAKE_NAME               = "take <предмет> <количество>";
MANPAGES_CCMD_TAKE_DESC               = "Забирает {{предмет}} у игрока - один, если не указано {{количество}}. Команду можно использовать для нанесения урона игроку: \"take health X\", где X - количество урона, и, если здоровье упадет до 0, игрок умрет. Используйте команду {{printinv}} для получения списка предметов в инвентаре. Дополнительно можно ознакомиться с командой {{give}}.";
MANPAGES_CCMD_TAKE_EXMP               = "";
MANPAGES_CCMD_TARGETINV_NAME          = "targetinv";
MANPAGES_CCMD_TARGETINV_DESC          = "Выполняет \"printinv\" для цели под прицелом, выводя список ее предметов инвентаря.";
MANPAGES_CCMD_TARGETINV_EXMP          = "";
MANPAGES_CCMD_TEAMLIST_NAME           = "teamlist";
MANPAGES_CCMD_TEAMLIST_DESC           = "Выводит список {{команд}}, определенных в {{TEAMINFO}}.";
MANPAGES_CCMD_TEAMLIST_EXMP           = "";
MANPAGES_CCMD_TESTCOLOR_NAME          = "testcolor <цвет>";
MANPAGES_CCMD_TESTCOLOR_DESC          = "Устанавливает {{цвет освещения}} во всех секторах, использующих освещение по умолчанию. {{Цвет}} может быть либо именем из лампа {{X11R6RGB}}, как \"MediumTurquoise\", либо шестнадцатеричной строкой цвета вроде \"0A6522\".";
MANPAGES_CCMD_TESTCOLOR_EXMP          = "";
MANPAGES_CCMD_TESTFADE_NAME           = "testfade <цвет>";
MANPAGES_CCMD_TESTFADE_DESC           = "Временно устанавливает {{цвет затухания}} текущего уровня. По умолчанию большинство уровней затухают в черный, но это можно изменить через {{MAPINFO}}. {{цвет}} может быть либо именем из лампа {{X11R6RGB}}, как \"MediumTurquoise\", либо шестнадцатеричной строкой цвета вроде \"0A6522\".";
