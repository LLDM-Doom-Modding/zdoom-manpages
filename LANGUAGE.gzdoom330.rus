MANPAGES_CCMD_REVERBEDIT_EXMP         = "";
MANPAGES_CCMD_REVERTENVIRONMENT_NAME  = "revertenvironment";
MANPAGES_CCMD_REVERTENVIRONMENT_DESC  = "Внутренняя команда отмены изменений в reverb-окружении, в первую очередь нужна в меню {{reverbedit}}. Вручную, из-под консоли, использовать ее нет смысла, она зависит от переменных reverbedit_name, reverbedit_id1 и reverbedit_id2, которые защищены от прямой записи.";
MANPAGES_CCMD_REVERTENVIRONMENT_EXMP  = "";
MANPAGES_CCMD_RNGSEED_NAME            = "rngseed (get|clear|set <значение>)";
MANPAGES_CCMD_RNGSEED_DESC            = "Управление начальным значением (ключом) генератора случайных чисел. Ключевое слово {{get}} выводит текущее значение ключа генерации в консоль; {{set}} устанавливает новое статическое значение ключа генерации; {{clear}} его сбрасывает. Важно заметить, что установка или сброс значения будет применяться только с новой игры.";
MANPAGES_CCMD_RNGSEED_EXMP            = "rngseed set 1234\tУстановить ключ генератора случайных чисел в {{1234}}.\nrngseed clear\tУбрать установленный ключ. Следующая игра начнется уже с другим начальным значением.";
MANPAGES_CCMD_R_SHOWCAPS_NAME         = "r_showcaps";
MANPAGES_CCMD_R_SHOWCAPS_DESC         = "Показать список возможностей текущего рендерера.";
MANPAGES_CCMD_R_SHOWCAPS_EXMP         = "";
MANPAGES_CCMD_SAVE_NAME               = "save <имя_файла> [описание]";
MANPAGES_CCMD_SAVE_DESC               = "Сохранить игру в файл {{имя_файла}} (расширение \".zds\" указывать необязательно) с заголовком {{описание}}. Директория файлов с сохранениями берется с переменной {{save_dir}} или, если она пуста, то по пути по умолчанию. Текущий путь для сохранений можно проверить через команду {{opensaves}}. Сохранение по абсолютному пути запрещено.";
MANPAGES_CCMD_SAVE_EXMP               = "save extra1\tСохраняет игру в файл {{extra1.zds}}.\nsave doom2map16.zds \"Doom 2, Suburbs\"\tСохраняет игру в файл {{doom2map16.zds}} под заголовком \"Doom 2, Suburbs\".\nsave ../../save.zds\tСпособ сохранения файла в другое места по относительному пути.";
MANPAGES_CCMD_SAVEREVERBS_NAME        = "savereverbs";
MANPAGES_CCMD_SAVEREVERBS_DESC        = "Внутренняя команда записи всех изменений reverb-редактора в файл конфигурации. В первую очередь нужна в меню {{reverbedit}}.";
MANPAGES_CCMD_SAVEREVERBS_EXMP        = "";
MANPAGES_CCMD_SELECTENVIRONMENT_NAME  = "selectenvironment";
MANPAGES_CCMD_SELECTENVIRONMENT_DESC  = "Внутренняя команда выбора существующего reverb-окружения, в первую очередь нужна в меню {{reverbedit}}. Вручную, из-под консоли, использовать ее нет смысла, она зависит от переменных reverbedit_name, reverbedit_id1 и reverbedit_id2, которые защищены от прямой записи.";
MANPAGES_CCMD_SELECTENVIRONMENT_EXMP  = "";
MANPAGES_CCMD_SETDATE_NAME            = "setdate <ЧЧ:ММ:СС ДД-ММ-ГГГГ>";
MANPAGES_CCMD_SETDATE_DESC            = "Установка внутри движка эмуляции даты-времени на указанное значение в формате \"ЧАСЫ:МИНУТЫ:СЕКУНДЫ ДЕНЬ-МЕСЯЦ-ГОД\" (синтаксис обязателен: два двоеточия, пробел и два дефиса). Получить его можно через команду {{getdate}}. Не затрагивает реальное время операционной системы.";
MANPAGES_CCMD_SETDATE_EXMP            = "setdate 21:33:07 31-12-2000\tБез пары часов Новый год нового тысячелетия!";
MANPAGES_CCMD_SETINV_NAME             = "setinv <предмет> <количество> [сверх_предела]";
MANPAGES_CCMD_SETINV_DESC             = "Установить число {{предметов}} инвентаря ровно в указанное {{количество}}. Если параметр {{сверх_предела}} указан как \"1\", установка будет игнорировать максимум предметов инвентаря. На месте слова {{предмет}} также можно использовать ключевое слово \"health\", которое устанавливает количество здоровья игрока.\n\nИмейте в виду, в части версий эта команда сломана и может привести к вылету игры! Родственные команды - {{give}} и {{take}}.";
MANPAGES_CCMD_SETINV_EXMP             = "setinv clip 100\tУстановить количество {{clip}} ровно в 100 предметов.\nsetinv health 999 1\tУстановить здоровье игрока в 999 пунктов (вне зависимости от того, есть ли предел в 100/200 единиц).";
MANPAGES_CCMD_SETREPLAYGAIN_NAME      = "setreplaygain <дБ>";
MANPAGES_CCMD_SETREPLAYGAIN_DESC      = "Усиление музыки, в дБ (допустимы значения от 0.0 до 10.0). Без параметра выводит текущее усиление. Требует запущенного плейлиста?";
MANPAGES_CCMD_SETREPLAYGAIN_EXMP      = "";
MANPAGES_CCMD_SHADERENABLE_NAME       = "shaderenable <название> <1|0|-1>";
MANPAGES_CCMD_SHADERENABLE_DESC       = "Включение или отключение шейдера {{название}}. Значение \"1\" включает шейдер, \"0\" отключает, \"-1\" переключает его.";
MANPAGES_CCMD_SHADERENABLE_EXMP       = "shaderenable myshader 1\tВключить шейдер {{myshader}}.";
MANPAGES_CCMD_SHADERUNIFORM_NAME      = "shaderuniform <шейдер> <переменная> [знач1 [знач2 [знач3]]]";
MANPAGES_CCMD_SHADERUNIFORM_DESC      = "Чтение или установка uniform-{{переменной}} указанного {{шейдера}}. Если нет {{значений 1-3}}, выводятся текущие значения переменной. Все неуказанные значения превращаются в \"0.0\".";
MANPAGES_CCMD_SHADERUNIFORM_EXMP      = "shaderuniform myshader somevec\tВывести значение uniform-переменной {{somevec}} в шейдере {{myshader}}.\nshaderuniform myshader e 2.71\tУстановить значение uniform-переменной {{myshader.e}} в \"2.71\".\nshaderuniform myshader vec3 2.71\tУстановить значение uniform-переменной {{myshader.vec3}} в \"(2.71, 0.0, 0.0)\".\nshaderuniform myshader vec3 1 2 3\tУстановить значение uniform-переменной {{myshader.vec3}} в \"(1.0, 2.0, 3.0)\".";
MANPAGES_CCMD_SND_RESET_NAME          = "snd_reset";
MANPAGES_CCMD_SND_RESET_DESC          = "Перезапуск звуковой подсистемы движка.";
MANPAGES_CCMD_SND_RESET_EXMP          = "";
MANPAGES_CCMD_SPYCANCEL_NAME          = "spycancel";
MANPAGES_CCMD_SPYCANCEL_DESC          = "Вернуться к своему телу при просмотре в мультиплеере экрана от лица другого игрока.";
MANPAGES_CCMD_SPYCANCEL_EXMP          = "";
MANPAGES_CCMD_TEST_NAME               = "test <выражение> <команда-при-успехе> [<команда-при-провале>]";
MANPAGES_CCMD_TEST_DESC               = "Вычисляет {{выражение}} и выполняет {{команду-при-успехе}}, если результат ненулевой. Если результат равен нулю, выполняется {{команда-при-провале}} (но ее может не быть).\n\nСинтаксис {{выражения}} такой же, как и у команды {{eval}}. Обратите внимание, если у {{команд-при-...}} есть хотя бы один аргумент, они должны быть обернуты в {{\"}}кавычки{{\"}}. Длинную строку обычно проще вынести наружу в виде псевдонима с помощью команды {{alias}}.";
MANPAGES_CCMD_TEST_EXMP               = "test 0 kill \"echo False!\"\tУбедиться, что \"0\" действительно вызывает вторую команду (или быть мгновенно убитым).\ntest 1 \"echo True!\" kill\tУбедиться, что ненулевое значение действительно вызывает первую команду (или быть мгновенно убитым).\n\ntest = + 2 2 4 \"echo 2+2 really is 4\"\tПодтвердить, что ZDoom правильно вычисляет базовую арифметику. Здесь не указана {{команда при провале}}.\n\ntest $cl_run \"echo Running by default\" \"echo Calm\"\tВывести разные сообщения в зависимости от переменной постоянного бега {{$cl_run}}.\n\ntest <= $screenblocks 10 \"echo Screenblocks: $screenblocks\" \"echo The view window is full size\"\tВывести разные сообщения в зависимости от результата выражения.";
MANPAGES_CCMD_TESTCUTSCENE_NAME       = "testcutscene <функция>";
MANPAGES_CCMD_TESTCUTSCENE_DESC       = "Запускает указанную катсцену.";
MANPAGES_CCMD_TESTCUTSCENE_EXMP       = "";
MANPAGES_CCMD_TESTFINALE_NAME         = "testfinale <строка> [язык]";
MANPAGES_CCMD_TESTFINALE_DESC         = "Запустить текстовую заставку между эпизодами, со {{строкой}} на указанном {{языке}} согласно таблице локализации. Символ \"$\" в начале строки подразумевается автоматически. {{Язык}} может состоять из двух или трех символов, а если он не указан, используется текущая локаль.\n\nДля вывода локализованного текста в консоль можно использовать команду {{printlocalized}}.";
MANPAGES_CCMD_TESTFINALE_EXMP         = "testfinale c2text\tЗапустить текстовый экран со строкой {{$C2TEXT}} (окончание второго эпизода Doom 2) на текущей локали.\ntestfinale c2text es\tЗапустить текстовый экран со строкой {{$C2TEXT}} на испанском языке.";
MANPAGES_CCMD_TOGGLEHUD_NAME          = "togglehud";
MANPAGES_CCMD_TOGGLEHUD_DESC          = "Временно отключает отображение HUD и рук с оружием, часто используется для создания скриншотов на картах. Для того, чтобы вернуть исходный вид, на многих версиях движка достаточно открыть и закрыть главное меню через {{Escape}}.";
MANPAGES_CCMD_TOGGLEHUD_EXMP          = "";
MANPAGES_CCMD_TOGGLEMESSAGES_NAME     = "togglemessages";
MANPAGES_CCMD_TOGGLEMESSAGES_DESC     = "Включение/отключение вывода сообщений во время игры. Эта команда не влияет на сохранение сообщений в буфере консоли.";
MANPAGES_CCMD_TOGGLEMESSAGES_EXMP     = "";
MANPAGES_CCMD_TYPE_NAME               = "type <файл>";
MANPAGES_CCMD_TYPE_DESC               = "Вывести содержимое загруженного текстового {{файла}} в консоль.";
MANPAGES_CCMD_TYPE_EXMP               = "type credits/icebrk1a.txt\tВывести содержимое файла {{credits/icebrk1a.txt}} (находится в *zdoom.pk3) - информация о первоисточнике используемого звука треска льда в портах ZDoom.";
MANPAGES_CCMD_TYPETABLE_NAME          = "typetable";
MANPAGES_CCMD_TYPETABLE_DESC          = "Отладочная команда с длинным выводом, пользователю не будет нужна никогда. Вывести все ячейки хэш-таблицы (в виде списков/цепочек) всех существующих внутренних типов, а также статистику по эффективности хэш-функции.";
MANPAGES_CCMD_TYPETABLE_EXMP          = "";
MANPAGES_CCMD_UNDOCOLORPIC_NAME       = "undocolorpic";
MANPAGES_CCMD_UNDOCOLORPIC_DESC       = "Команда, предназначенная исключительно для меню выбора цвета \"ColorpickerMenu\", соответствует там кнопке \"Отменить изменения\". Неприменима при работе через консоль.";
MANPAGES_CCMD_UNDOCOLORPIC_EXMP       = "";
MANPAGES_CCMD_VID_LIST_SDL_RENDER_DRIVERS_NAME = "vid_list_sdl_render_drivers";
MANPAGES_CCMD_VID_LIST_SDL_RENDER_DRIVERS_DESC = "Вывод всех доступных драйверов для отрисовки через SDL.";
MANPAGES_CCMD_VID_LIST_SDL_RENDER_DRIVERS_EXMP = "";
MANPAGES_CCMD_VID_SCALETOHEIGHT_NAME  = "vid_scaletoheight <высота>";
MANPAGES_CCMD_VID_SCALETOHEIGHT_DESC  = "Установка эмулируемой {{высоты}} разрешения экрана для подгонки окна отображения игры. Обычно удобнее пользоваться меню \"Настройки\" -> \"Видеорежим\".";
MANPAGES_CCMD_VID_SCALETOHEIGHT_EXMP  = "vid_scaletoheight 1080\tУстановить высоту в 1080 пикселей (FullHD).\"";
MANPAGES_CCMD_VID_SCALETOLOWEST_NAME  = "vid_scaletolowest";
MANPAGES_CCMD_VID_SCALETOLOWEST_DESC  = "Подгонка окна под минимально возможное разрешение с текущими харакретистиками экрана. Обычно удобнее пользоваться меню \"Настройки\" -> \"Видеорежим\".";
MANPAGES_CCMD_VID_SCALETOLOWEST_EXMP  = "";
MANPAGES_CCMD_VID_SCALETOWIDTH_NAME   = "vid_scaletowidth <ширина>";
MANPAGES_CCMD_VID_SCALETOWIDTH_DESC   = "Установка эмулируемой {{ширины}} разрешения экрана для подгонки окна отображения игры. Обычно удобнее пользоваться меню \"Настройки\" -> \"Видеорежим\".";
MANPAGES_CCMD_VID_SCALETOWIDTH_EXMP   = "vid_scaletoheight 1920\tУстановить высоту в 1920 пикселей (FullHD).\"";
MANPAGES_CCMD_VID_SETSCALE_NAME       = "vid_setscale <x> <y> [линейно] [pixel-shape]";
MANPAGES_CCMD_VID_SETSCALE_DESC       = "Установка разрешения нового окна отображения по заданным параметрам. Обычно удобнее пользоваться меню \"Настройки\" -> \"Видеорежим\".";
MANPAGES_CCMD_VID_SETSCALE_EXMP       = "";
MANPAGES_CCMD_VID_SETSIZE_NAME        = "vid_setsize";
MANPAGES_CCMD_VID_SETSIZE_DESC        = "Установка размера окна отображения. Обычно удобнее пользоваться меню \"Настройки\" -> \"Видеорежим\".";
MANPAGES_CCMD_VID_SETSIZE_EXMP        = "";
MANPAGES_CCMD_VID_SHOWCURRENTSCALING_NAME = "vid_showcurrentscaling";
MANPAGES_CCMD_VID_SHOWCURRENTSCALING_DESC = "Показать текущие параметры окна отображения (масштабирование, реальное разрешение текущего экрана и эмулируемое разрешение экрана). Обычно удобнее пользоваться меню \"Настройки\" -> \"Видеорежим\".";
MANPAGES_CCMD_VID_SHOWCURRENTSCALING_EXMP = "";
MANPAGES_CCMD_VK_LISTDEVICES_NAME     = "vk_listdevices";
MANPAGES_CCMD_VK_LISTDEVICES_DESC     = "Отобразить все устройства (GPU), с которыми может работать Vulkan.";
MANPAGES_CCMD_VK_LISTDEVICES_EXMP     = "";
MANPAGES_CCMD_VMENGINE_NAME           = "vmengine <default|checked|unchecked>";
MANPAGES_CCMD_VMENGINE_DESC           = "Можно применить только при запуске движка. При компиляции без JIT установить виртуальную машину \"VMExec\" в проверяемый вариант ({{checked}}), непроверяемый ({{unchecked}}), или сбросить до версии по умолчанию (вариант {{default}}, определяется по наличию {{#define NDEBUG}} при сборке, в большинстве сборок этот вариант соответствует варианту {{checked}}). Применяется только для функций, которые не были JIT-скомпилированы.\n\nС учетом того, что сейчас во всех движках JIT-компиляция включена по умолчанию, полезность команды под вопросом.";
MANPAGES_CCMD_VMENGINE_EXMP           = "";
MANPAGES_CCMD_WRITEINI_NAME           = "writeini [ini-файл]";
MANPAGES_CCMD_WRITEINI_DESC           = "Записать текущую конфигурацию в файл конфигурации. Можно указать аргумент {{ini-файл}}, тогда запись будет производиться в него, при этом допустимо указывать произвольный путь в файловой системе.";
MANPAGES_CCMD_WRITEINI_EXMP           = "writeini test.ini\tЗаписать конфигурацию в файл {{test.ini}}.\nwriteini C:\\Temp\\test.ini\tЗаписать конфигурацию в файл по пути {{C:\\Temp\\test.ini}} (если есть права на запись).";
MANPAGES_CCMD_WRITEMIDI_NAME          = "writemidi <название> <выходной_файл(!)>";
MANPAGES_CCMD_WRITEMIDI_DESC          = "Сохранить MIDI-трек с указанным {{названием}} в файл. Допустимо на месте названия использовать символ \"*\", чтобы записать на диск текущий проигрываемый трек.\n\nВнимание! Практически на всех версиях движка из-за ошибки аргумент {{выходной_файл}} игнорируется, и выходной файл всегда называется также, как и сам MIDI-трек. Возможно, лучшим решением будет воспользоваться редактором ресурсов.";
MANPAGES_CCMD_WRITEMIDI_EXMP          = "writemidi d_romero x.mid\tЗаписать композицию {{d_romero}} из Doom 2 в файл \"d_romero\" (или в файл \"{{x.mid}}\", если в текущей версии движка ошибка уже исправлена).";
MANPAGES_CCMD_WRITEWAVE_NAME          = "writewave <midi> <выходной файл> [subsong] [частота дискретизации] [название синтезатора] [soundfont]";
MANPAGES_CCMD_WRITEWAVE_DESC          = "Записать MIDI как файл RIFF WAV с указанными параметрами. На месте параметра {{название синтезатора}} могут стоять названия \"WildMidi\", \"GUS\", \"Timidity\", \"FluidSynth\", \"OPL\", \"OPN\" или \"ADL\", по умолчанию используется \"FluidSynth\". Допустимо на месте названия {{midi}} использовать символ \"*\", чтобы записать на диск текущий проигрываемый трек. Если на месте {{subsong}} и {{частота дискретизации}} стоит \"0\", используются свойства, заданные самим треком.\n\nВнимание! Передаваемые аргументы практически не проверяются на корректность, игра может вылететь. Возможно, лучшим решением будет воспользоваться редактором ресурсов.";
MANPAGES_CCMD_WRITEWAVE_EXMP          = "";
