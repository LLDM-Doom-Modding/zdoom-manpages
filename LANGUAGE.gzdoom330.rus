MANPAGES_CCMD_WEAPDROP_NAME           = "weapdrop";
MANPAGES_CCMD_WEAPDROP_DESC           = "Выбрасывает текущее выбранное {{оружие}}.";
MANPAGES_CCMD_WEAPDROP_EXMP           = "";
MANPAGES_CCMD_WEAPNEXT_NAME           = "weapnext";
MANPAGES_CCMD_WEAPNEXT_DESC           = "Выбирает следующее {{оружие}} (по порядку), которое у вас есть и для которого есть {{боеприпасы}}. Также воспроизводит звук \"misc/weaponchange\", если он определен (по умолчанию - нет).";
MANPAGES_CCMD_WEAPNEXT_EXMP           = "";
MANPAGES_CCMD_WEAPONSECTION_NAME      = "weaponsection <секция_ini>";
MANPAGES_CCMD_WEAPONSECTION_DESC      = "Эта команда аналогична {{addkeysection}}. При выполнении она загружает все назначения оружейных слотов из соответствующей секции в {{ini-файле конфигурации}}. При выходе из игры слоты будут сохранены в указанную секцию вместо стандартной, чтобы не перезаписывать обычные настройки игрока.";
MANPAGES_CCMD_WEAPONSECTION_EXMP      = "";
