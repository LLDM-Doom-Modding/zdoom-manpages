MANPAGES_CCMD_SND_STATUS_EXMP         = "";
MANPAGES_CCMD_SOUNDLINKS_NAME         = "soundlinks";
MANPAGES_CCMD_SOUNDLINKS_DESC         = "Выводит список связей между различными звуками, использующими одни и те же данные. Связи создаются динамически во время игры, поэтому результаты команды могут отличаться в разных сессиях или в разное время одной игры.";
MANPAGES_CCMD_SOUNDLINKS_EXMP         = "";
MANPAGES_CCMD_SOUNDLIST_NAME          = "soundlist";
MANPAGES_CCMD_SOUNDLIST_DESC          = "Выводит список всех определенных звуков и лампов, на которые они ссылаются. В отличие от обычного {{Doom}}, ZDoom обращается к звукам по длинным именам и использует ламп {{SNDINFO}} для их сопоставления с лампами в WAD-файле. Логические звуки, ссылающиеся на одни и те же данные, будут связаны для предотвращения загрузки нескольких копий одного звука в память.";
MANPAGES_CCMD_SOUNDLIST_EXMP          = "";
MANPAGES_CCMD_SPECIAL_NAME            = "special <спец_действие> [арг1 [арг2 [арг3 [арг4 [арг5]]]]]";
MANPAGES_CCMD_SPECIAL_DESC            = "Выполняет {{специальное действие}} (action special) на текущей карте, опционально передавая ему до пяти числовых аргументов.";
MANPAGES_CCMD_SPECIAL_EXMP            = "special thrustthingz 0 30 0 1\tАналог высокого прыжка посредством вызова {{ThrustThingZ( 0, 30, 0, 1 )}}.\nspecial 128 0 30 0 1\t{{128}} - это индекс для {{ThrustThingZ()}}, поэтому здесь вызывается то же, что и в выше.\nspecial Sector_SetFriction 0 150\tСделать пол всех секторов уровня с нулевым тегом (на практике почти всех) более скользким.\nspecial Sector_SetColor 0 255 127 127\tПерекрасить все секторы с нулевым тегом с помощью {{Sector_SetColor()}} в красноватый цвет.";
MANPAGES_CCMD_SPRAY_NAME              = "spray <декаль>";
MANPAGES_CCMD_SPRAY_DESC              = "Рисует указанный {{декаль}} на ближайшей стене, чтобы можно было увидеть, как он выглядит.";
MANPAGES_CCMD_SPRAY_EXMP              = "";
MANPAGES_CCMD_SPYNEXT_NAME            = "spynext";
MANPAGES_CCMD_SPYNEXT_DESC            = "Во время {{кооперативной}} игры или просмотра {{многопользовательской}} {{демки}} эта команда переключает вид на следующего игрока.";
