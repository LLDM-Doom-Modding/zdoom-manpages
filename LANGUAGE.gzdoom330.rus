MANPAGES_CCMD_UTID_NAME               = "utid [начало [лимит]]";
MANPAGES_CCMD_UTID_DESC               = "Выводит неиспользованный {{TID}}. Если {{начало}} равно 0 или не указано, будет выбран случайный TID. В противном случае будет выполнен линейный поиск ближайшего не назначенный TID, начиная с указанного значения. Если задан отличный от нуля {{лимит}}, поиск проверит ближайшие TID количеством не более чем это значение. Выводит 0, если подходящий TID не найден.";
MANPAGES_CCMD_UTID_EXMP               = "";
MANPAGES_CCMD_VID_LISTADAPTERS_NAME   = "vid_listadapters";
