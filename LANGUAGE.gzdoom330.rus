MANPAGES_CCMD_LISTMAPS_NAME           = "listmaps";
MANPAGES_CCMD_LISTMAPS_DESC           = "Выводит в консоль список всех карт, определенных в {{MAPINFO}}, вместе с именами их lump-файлов. Это может облегчить поиск карты с нестандартным именем лампа. Также указывает, какой файл содержит карту.";
