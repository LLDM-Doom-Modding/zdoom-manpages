MANPAGES_CCMD_QUICKLOAD_DESC          = "Вызвать диалог быстрой загрузки, аналогично нажатию {{F9}} при стандарных настройках клавиатуры.";
MANPAGES_CCMD_QUICKLOAD_EXMP          = "";
