MANPAGES_CCMD_NET_REMOVECONTROLLER_NAME = "net_removecontroller <игрок>";
MANPAGES_CCMD_NET_REMOVECONTROLLER_DESC = "Удаляет игрока из списка арбитров сетевой игры.";
MANPAGES_CCMD_NET_REMOVECONTROLLER_EXMP = "";
MANPAGES_CCMD_NEXTMAP_NAME            = "nextmap";
MANPAGES_CCMD_NEXTMAP_DESC            = "Перемещает игрока на следующую карту, указанную в {{MAPINFO}}. Также сбрасывает инвентарь и здоровье игрока, как если бы началась новая игра.";
MANPAGES_CCMD_NEXTMAP_EXMP            = "";
MANPAGES_CCMD_NEXTSECRET_NAME         = "nextsecret";
MANPAGES_CCMD_NEXTSECRET_DESC         = "Перемещает игрока на текущую секретную карту, указанную в {{MAPINFO}}, как если бы он нашел секретный выход. Также сбрасывает инвентарь и здоровье игрока, как если бы началась новая игра.";
MANPAGES_CCMD_NEXTSECRET_EXMP         = "";
MANPAGES_CCMD_NOCLIP_NAME             = "noclip";
MANPAGES_CCMD_NOCLIP_DESC             = "Включает/выключает режим прохождения сквозь стены. В этом режиме движение в горизонтальной плоскости ничем не ограничено - можно проходить сквозь стены и твердые объекты, а также подниматься на любую высоту. Это полезно для прохождения сквозь запертые двери или быстрого доступа к дальним частям карты.";
MANPAGES_CCMD_NOCLIP_EXMP             = "";
MANPAGES_CCMD_NOCLIP2_NAME            = "noclip2";
MANPAGES_CCMD_NOCLIP2_DESC            = "Включает/выключает второй режим прохождения сквозь стены. Аналогичен команде {{noclip}}, но также включает флаг {{NOGRAVITY}} и дает возможность пролетать сквозь {{3D-полы}}.";
MANPAGES_CCMD_NOCLIP2_EXMP            = "";
MANPAGES_CCMD_NOTARGET_NAME           = "notarget";
MANPAGES_CCMD_NOTARGET_DESC           = "Включает/выключает режим \"невидимости\". Пока он активен, монстры не будут атаковать вас, пока вы не ударите их первым. В \"современных шутерах\" монстры \"не могут найти вас\" в этом режиме. В ZDoom это не так.";
MANPAGES_CCMD_NOTARGET_EXMP           = "";
MANPAGES_CCMD_OPEN_NAME               = "open <путь_и_имя_файла> [dm|coop]";
MANPAGES_CCMD_OPEN_DESC               = "Открывает указанный файл и загружает первую найденную в нем карту. Остальное содержимое файла игнорируется (графика, звуки, {{MAPINFO}}, определения акторов, карты после первой и т. д.). Именем и слотом карты станет имя файла, а не фактический слот внутри него. Инвентарь и здоровье сбрасываются. Нельзя использовать в мультиплеере. Как и в случае с {{map}}, можно добавить {{dm}} или {{coop}} для эмуляции {{мультиплеера}}. По умолчанию - одиночный режим.";
MANPAGES_CCMD_OPEN_EXMP               = "";
MANPAGES_CCMD_OPENMENU_NAME           = "openmenu <имя_меню>";
MANPAGES_CCMD_OPENMENU_DESC           = "Открывает указанное {{меню}}, используя его имя из {{MENUDEF}}.";
MANPAGES_CCMD_OPENMENU_EXMP           = "";
MANPAGES_CCMD_PAUSE_NAME              = "pause";
MANPAGES_CCMD_PAUSE_DESC              = "Переключает паузу игры.";
MANPAGES_CCMD_PAUSE_EXMP              = "";
MANPAGES_CCMD_PINGS_NAME              = "pings";
MANPAGES_CCMD_PINGS_DESC              = "Выводит очень грубую оценку скорости соединения между вашим компьютером и другими участниками игры. Строго говоря, значения, выводимые этой командой, не являются пингами; это просто количество миллисекунд, прошедших с момента последнего получения сетевого пакета от других машин.";
MANPAGES_CCMD_PINGS_EXMP              = "";
MANPAGES_CCMD_PLAYDEMO_NAME           = "playdemo <демо-файл>";
MANPAGES_CCMD_PLAYDEMO_DESC           = "Запускает демо-запись. Демка может быть файлом на диске или лампом (lump) в WAD-файле.";
MANPAGES_CCMD_PLAYDEMO_EXMP           = "";
MANPAGES_CCMD_PLAYERCLASSES_NAME      = "playerclasses";
MANPAGES_CCMD_PLAYERCLASSES_DESC      = "Выводит список всех доступных {{классов игроков}}, указывая для каждого номер (начиная с нуля), имя актора класса и его отображаемое имя.";
MANPAGES_CCMD_PLAYERCLASSES_EXMP      = "";
MANPAGES_CCMD_PLAYERINFO_NAME         = "playerinfo [игрок]";
MANPAGES_CCMD_PLAYERINFO_DESC         = "Без параметров выводит номера всех игроков в игре. Если указан {{игрок}}, будут выведены подробности пользовательской информации этого игрока.";
MANPAGES_CCMD_PLAYERINFO_EXMP         = "";
MANPAGES_CCMD_PLAYERSOUNDS_NAME       = "playersounds";
MANPAGES_CCMD_PLAYERSOUNDS_DESC       = "Выводит список звуков игрока, определенных для каждого класса и скина.";
MANPAGES_CCMD_PLAYERSOUNDS_EXMP       = "";
MANPAGES_CCMD_PLAYLIST_NAME           = "playlist <плейлист.m3u> [shuffle|позиция]";
MANPAGES_CCMD_PLAYLIST_DESC           = "Загружает плейлист WinAmp в формате .m3u. Обычная игровая музыка будет игнорироваться, вместо нее будут воспроизводиться песни из плейлиста. Если добавить слово {{shuffle}} после имени файла, плейлист будет воспроизводиться в случайном порядке. Вместо {{shuffle}} можно указать {{позицию}} - номер песни в плейлисте, с которой нужно начать.";
MANPAGES_CCMD_PLAYLIST_EXMP           = "";
MANPAGES_CCMD_PLAYLISTNEXT_NAME       = "playlistnext";
MANPAGES_CCMD_PLAYLISTNEXT_DESC       = "Воспроизводит следующую песню в плейлисте.";
MANPAGES_CCMD_PLAYLISTNEXT_EXMP       = "";
MANPAGES_CCMD_PLAYLISTPOS_NAME        = "playlistpos <позиция>";
MANPAGES_CCMD_PLAYLISTPOS_DESC        = "Начинает воспроизведение песни с указанной {{позиции}} в плейлисте.";
MANPAGES_CCMD_PLAYLISTPOS_EXMP        = "";
MANPAGES_CCMD_PLAYLISTPREV_NAME       = "playlistprev";
MANPAGES_CCMD_PLAYLISTPREV_DESC       = "Воспроизводит предыдущую песню в плейлисте.";
MANPAGES_CCMD_PLAYLISTPREV_EXMP       = "";
MANPAGES_CCMD_PLAYLISTSTATUS_NAME     = "playliststatus";
MANPAGES_CCMD_PLAYLISTSTATUS_DESC     = "Отображает количество песен в плейлисте и текущую композицию.";
MANPAGES_CCMD_PLAYLISTSTATUS_EXMP     = "";
MANPAGES_CCMD_PLAYSEQUENCE_NAME       = "playsequence <последовательность> [<номер>]";
MANPAGES_CCMD_PLAYSEQUENCE_DESC       = "Воспроизводит {{звуковую последовательность}} на локальной машине. Если номер не указан, используется 0. {{Последовательность}} должна быть определена в {{SNDSEQ}}.";
MANPAGES_CCMD_PLAYSEQUENCE_EXMP       = "";
MANPAGES_CCMD_PLAYSOUND_NAME          = "playsound <звук>";
MANPAGES_CCMD_PLAYSOUND_DESC          = "Воспроизводит звук на локальной машине. Как и все остальные звуки в игре, {{звук}} должен быть правильно определен в лампе {{SNDINFO}} перед использованием.";
MANPAGES_CCMD_PLAYSOUND_EXMP          = "";
MANPAGES_CCMD_POWERUP_NAME            = "powerup";
MANPAGES_CCMD_POWERUP_DESC            = "Дает усиление в Heretic, как если бы вы использовали Том Могущества (Tome of Power).";
MANPAGES_CCMD_POWERUP_EXMP            = "";
MANPAGES_CCMD_PRINT_NAME              = "print <строка>";
MANPAGES_CCMD_PRINT_DESC              = "Выводит именованную строку в консоль. Это строки, которые можно редактировать с помощью bex-патчей.";
MANPAGES_CCMD_PRINT_EXMP              = "";
MANPAGES_CCMD_PRINTINV_NAME           = "printinv";
MANPAGES_CCMD_PRINTINV_DESC           = "Выводит ваш текущий инвентарь в консоль.";
MANPAGES_CCMD_PRINTINV_EXMP           = "";
MANPAGES_CCMD_PRINTSTATS_NAME         = "printstats";
MANPAGES_CCMD_PRINTSTATS_DESC         = "Выводит статистику (убийства, секреты, предметы и время) для каждого уровня в текущей игре.";
MANPAGES_CCMD_PRINTSTATS_EXMP         = "";
MANPAGES_CCMD_PUKE_NAME               = "puke <скрипт> [арг1 [арг2 [арг3]]]";
MANPAGES_CCMD_PUKE_DESC               = "Выполняет {{ACS}}-скрипт на текущей карте, опционально передавая ему до трех числовых аргументов. В {{многопользовательской игре}} для этого обычно должны быть включены {{sv_cheats}}. Однако, если скрипт имеет ключевое слово \"net\", его может активировать любой игрок. Если аргумент {{скрипт}} отрицательный, он будет выполнен через {{ACS_ExecuteAlways}}; в противном случае - через {{ACS_Execute}}. Скрипт 0 зарезервирован для поддержки {{Strife}} и не может быть вызван через puke.";
MANPAGES_CCMD_PUKE_EXMP               = "";
MANPAGES_CCMD_PUKENAME_NAME           = "pukename <скрипт> [always] [арг1 [арг2 [арг3]]]";
MANPAGES_CCMD_PUKENAME_DESC           = "Выполняет {{именованный скрипт}} на текущей карте, опционально передавая ему до трех числовых аргументов. В {{многопользовательской игре}} для этого обычно должны быть включены {{sv_cheats}}. Однако, если скрипт имеет ключевое слово \"net\", его может активировать любой игрок. Если после имени скрипта (и перед любыми аргументами) указано ключевое слово {{always}}, скрипт будет выполнен через {{ACS_NamedExecuteAlways}}; в противном случае - через {{ACS_NamedExecute}}.";
MANPAGES_CCMD_PUKENAME_EXMP           = "";
MANPAGES_CCMD_PULLIN_NAME             = "pullin <wad-файл>";
MANPAGES_CCMD_PULLIN_DESC             = "Загружает WAD-файл при запуске. Эта команда действительна только внутри .cfg файлов, которые были выполнены при запуске.";
MANPAGES_CCMD_PULLIN_EXMP             = "";
MANPAGES_CCMD_REBIND_NAME             = "rebind <команда>";
MANPAGES_CCMD_REBIND_DESC             = "Изменяет привязку клавиши, нажатие которой вызвало выполнение команды rebind. По очевидным причинам эту команду нельзя использовать напрямую из консоли. Например, эта команда приведет к тому, что первое нажатие \"b\" выведет \"setting 1\", а все последующие - \"setting 2\": bind b \"echo setting 1; rebind \\"echo setting 2\\"\"";
MANPAGES_CCMD_REBIND_EXMP             = "";
MANPAGES_CCMD_RECORDMAP_NAME          = "recordmap <имя_файла> <имя_карты> [dm|coop]";
MANPAGES_CCMD_RECORDMAP_DESC          = "Запускает новую игру на указанной карте, записывая демо в указанный файл. Использование \"*\" вместо имени карты записывает демо на текущей карте. Опционально можно добавить ключевые слова {{dm}} или {{coop}} для эмуляции {{многопользовательской игры}}. По умолчанию - одиночный режим.";
MANPAGES_CCMD_RECORDMAP_EXMP          = "";
MANPAGES_CCMD_REMOVE_NAME             = "remove <класс>";
MANPAGES_CCMD_REMOVE_DESC             = "Удаляет все объекты указанного типа с текущей карты, за исключением живых игроков.\n\n{{ВНИМАНИЕ:}} Удаление кукол вуду (voodoo dolls) может сломать карты, полагающиеся на активацию ими специальных линий; этого следует избегать.\n\n{{ПРИМЕЧАНИЕ:}} У этой команды нет категорий, она работает только с именами акторов. То есть \"remove monsters\" не удалит всех монстров, хотя расширение этой команды для поддержки категорий планируется.";
MANPAGES_CCMD_REMOVE_EXMP             = "";
MANPAGES_CCMD_REMOVEBOTS_NAME         = "removebots";
MANPAGES_CCMD_REMOVEBOTS_DESC         = "Удаляет всех ботов из игры. Боты также будут автоматически удалены из сетевых игр, когда выйдет сетевой арбитр (обычно это игрок-хост).";
MANPAGES_CCMD_REMOVEBOTS_EXMP         = "";
MANPAGES_CCMD_RESET2DEFAULTS_NAME     = "reset2defaults";
MANPAGES_CCMD_RESET2DEFAULTS_DESC     = "Сбрасывает все {{консольные переменные}} и привязки клавиш к их значениям по умолчанию.";
MANPAGES_CCMD_RESET2DEFAULTS_EXMP     = "";
MANPAGES_CCMD_RESET2SAVED_NAME        = "reset2saved";
MANPAGES_CCMD_RESET2SAVED_DESC        = "Сбрасывает все {{консольные переменные}} и привязки клавиш к значениям, которые сохранены в {{ini-файле конфигурации}}.";
MANPAGES_CCMD_RESET2SAVED_EXMP        = "";
MANPAGES_CCMD_RESETCVAR_NAME          = "resetcvar <cvar>";
MANPAGES_CCMD_RESETCVAR_DESC          = "Сбрасывает {{cvar}} к значению по умолчанию.";
MANPAGES_CCMD_RESETCVAR_EXMP          = "";
MANPAGES_CCMD_RESURRECT_NAME          = "resurrect";
MANPAGES_CCMD_RESURRECT_DESC          = "Воскрешает игрока, если он мертв (возвращает к жизни со 100% здоровья). Примечание: нельзя использовать, если игрок \"рассыпался\" (например, разбит на куски после заморозки).";
MANPAGES_CCMD_RESURRECT_EXMP          = "";
MANPAGES_CCMD_SAY_NAME                = "say <сообщение>";
MANPAGES_CCMD_SAY_DESC                = "Отправляет сообщение всем игрокам. Если сообщение начинается с \"/me\", то \"/me\" будет заменено на ваше имя (как в IRC).";
MANPAGES_CCMD_SAY_EXMP                = "";
MANPAGES_CCMD_SAY_TEAM_NAME           = "say_team <сообщение>";
MANPAGES_CCMD_SAY_TEAM_DESC           = "То же самое, что и say, но отправляет сообщение только вашим товарищам по команде. Если командная игра неактивна, команда сработает как обычный say и отправит сообщение всем.";
MANPAGES_CCMD_SAY_TEAM_EXMP           = "";
MANPAGES_CCMD_SCREENSHOT_NAME         = "screenshot [файл]";
MANPAGES_CCMD_SCREENSHOT_DESC         = "Сохраняет {{копию экрана}} на диск в формате PNG или PCX. Если файл не указан, имя скриншота будет создано автоматически и будет включать название используемого IWAD и время снимка.";
