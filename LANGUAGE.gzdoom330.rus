MANPAGES_CCMD_ITEMS_NAME              = "items [класс или TID]";
MANPAGES_CCMD_ITEMS_DESC              = "Выводит список всех {{предметов}} на карте, каждый в строке вида ClassName at (X, Y, Z).\n\nЕсли передать имя класса предмета, список будет отфильтрован. В конце списка печатается общее количество найденных предметов. Передача {{TID}} вместо имени класса фильтрует список по {{TID}}.";
MANPAGES_CCMD_ITEMS_EXMP              = "";
MANPAGES_CCMD_ITEMSNUM_NAME           = "itemsnum [класс или TID]";
MANPAGES_CCMD_ITEMSNUM_DESC           = "Выводит общее количество всех предметов на карте. Если передать имя класса предмета, будет выведено количество только этого класса. Если вместо имени класса указать {{TID}}, будет выведено количество предметов с указанным {{TID}}.";
MANPAGES_CCMD_ITEMSNUM_EXMP           = "";
MANPAGES_CCMD_KEY_NAME                = "key <значение1> [значение2]";
MANPAGES_CCMD_KEY_DESC                = "Преобразует все параметры команды в соответствующие значения клавиш, которые используются внутри движка для поиска команд и алиасов. Вероятно, не очень полезно для обычного пользователя.";
MANPAGES_CCMD_KEY_EXMP                = "";
MANPAGES_CCMD_KILL_NAME               = "kill [класс]";
MANPAGES_CCMD_KILL_DESC               = "Без аргументов убивает игрока. Можно указать \"kill monsters\" для убийства всех монстров на уровне или \"kill baddies\" для убийства всех враждебных монстров. Команда также предотвращает появление новых акторов при смерти старых (например, Элементаль Боли не создаст Потерянных Душ). Если указан класс, убивает всех акторов этого типа. {{ПРИМЕЧАНИЕ:}} Команда не может уничтожить акторов с флагом {{NODAMAGE}}. Это можно обойти, задав {{PainChance}} \"Massacre\" на 256. В этом случае монстр должен выполнить {{A_ChangeFlag}} для снятия флага и вызвать {{A_Die}}(\"Extreme\") после задержки в один тик.";
MANPAGES_CCMD_KILL_EXMP               = "";
MANPAGES_CCMD_LAND_NAME               = "land";
MANPAGES_CCMD_LAND_DESC               = "Если сейчас используется предмет {{полета}}, команда деактивирует его и заставит вас приземлиться.";
MANPAGES_CCMD_LAND_EXMP               = "";
MANPAGES_CCMD_LINETARGET_NAME         = "linetarget [подробно]";
MANPAGES_CCMD_LINETARGET_DESC         = "Отображает имя, текущее и начальное здоровье ближайшего актора по линии огня. Если параметр {{подробно}} не равен нулю, выводится дополнительная информация, аналогично команде {{info}}.";
