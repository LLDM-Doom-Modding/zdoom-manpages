MANPAGES_CCMD_MESSAGEMODE_NAME        = "messagemode";
MANPAGES_CCMD_MESSAGEMODE_DESC        = "Включает режим ввода сообщения. Все, что набрано в этом режиме, будет отправлено остальным игрокам (аналогично команде say) после нажатия Enter.";
MANPAGES_CCMD_MESSAGEMODE_EXMP        = "";
MANPAGES_CCMD_MONSTER_NAME            = "monster [класс или TID]";
MANPAGES_CCMD_MONSTER_DESC            = "Выводит список всех живых враждебных {{монстров}} на карте, каждый в строке вида ClassName at (X, Y, Z).\n\nЕсли передать имя класса монстра, список будет отфильтрован. В конце списка печатается общее количество найденных монстров. Передача {{TID}} вместо имени класса фильтрует список по {{TID}}.";
MANPAGES_CCMD_MONSTER_EXMP            = "";
MANPAGES_CCMD_MONSTERNUM_NAME         = "monsternum [класс или TID]";
MANPAGES_CCMD_MONSTERNUM_DESC         = "Выводит общее количество всех живых враждебных монстров на карте. Если передать имя класса монстра, будет выведено количество только этого класса. Если вместо имени класса указать {{TID}}, будет выведено количество монстров с указанным {{TID}}.";
MANPAGES_CCMD_MONSTERNUM_EXMP         = "";
MANPAGES_CCMD_MORPHME_NAME            = "morphme [класс]";
MANPAGES_CCMD_MORPHME_DESC            = "Превращает вас в курицу в Heretic или в свинью в Hexen и Doom (для последнего нужны соответствующие ресурсы графики). Если указан {{класс}}, команда попытается превратить вас в него. Это сработает только если целевой класс наследуется от PlayerPawn и вы не находитесь в состоянии, запрещающем морфинг (например, мертвы).";
MANPAGES_CCMD_MORPHME_EXMP            = "";
MANPAGES_CCMD_MYINFO_NAME             = "myinfo";
MANPAGES_CCMD_MYINFO_DESC             = "Выводит подробную информацию об объекте игрока (PlayerPawn), которым вы управляете, аналогично команде \"info\".";
MANPAGES_CCMD_MYINFO_EXMP             = "";
MANPAGES_CCMD_NET_ADDCONTROLLER_NAME  = "net_addcontroller <игрок>";
MANPAGES_CCMD_NET_ADDCONTROLLER_DESC  = "Добавляет игрока в список арбитров сетевой игры, которые могут изменять настройки игры.";
MANPAGES_CCMD_NET_ADDCONTROLLER_EXMP  = "";
MANPAGES_CCMD_NET_LISTCONTROLLERS_NAME = "net_listcontrollers";
