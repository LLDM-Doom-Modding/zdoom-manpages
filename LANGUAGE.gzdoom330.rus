MANPAGES_CCMD_IDDQD_EXMP              = "";
MANPAGES_CCMD_IDMUS_NAME              = "idmus <номер_слота>";
MANPAGES_CCMD_IDMUS_DESC              = "Меняет музыку на связанную с указанным уровнем. Эмулирует чит-код {{idmus}}.";
MANPAGES_CCMD_IDMUS_EXMP              = "";
MANPAGES_CCMD_INFO_NAME               = "info [подробно]";
MANPAGES_CCMD_INFO_DESC               = "Выводит подробную информацию об акторе, на которого смотрит игрок. Команда не может обнаружить акторов с радиусом или высотой 0, а также акторов с флагом {{NOBLOCKMAP}}. Если параметр {{подробно}} равен 0, отображаются только имя актора, текущее и начальное здоровье.";
MANPAGES_CCMD_INFO_EXMP               = "";
MANPAGES_CCMD_INVDROP_NAME            = "invdrop";
MANPAGES_CCMD_INVDROP_DESC            = "Выбрасывает текущий выбранный {{предмет инвентаря}}.";
MANPAGES_CCMD_INVDROP_EXMP            = "";
MANPAGES_CCMD_INVNEXT_NAME            = "invnext";
MANPAGES_CCMD_INVNEXT_DESC            = "Выбирает следующий {{предмет инвентаря}} в вашем распоряжении. Кроме того, воспроизводит звук \"misc/invchange\", если он определен (по умолчанию - нет).";
